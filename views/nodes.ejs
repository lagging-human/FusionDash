<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>
<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-xs text-zinc-500"><a href="/admin" class="hover:text-zinc-300 transition-colors">Admin</a> <span class="text-zinc-700">/ Nodes</span></p>
      <p class="text-sm font-semibold text-white mt-0.5">Node Management</p>
      <p class="text-xs text-zinc-600 mt-0.5">Synced from your Pterodactyl panel. Refresh the page to re-sync.</p>
    </div>
    <a href="/admin/nodes" class="inline-flex items-center gap-x-1.5 rounded-full bg-zinc-700/50 px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700 transition-colors">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/></svg>
      Sync Nodes
    </a>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'nodes' }) %>

  <%
    const stateInfo = {
      active:  { label:'Active',   cls:'bg-green-500/10 text-green-400 ring-1 ring-green-500/20',   dot:'bg-green-400',   desc:'Users can create servers on this node.' },
      full:    { label:'Full',     cls:'bg-amber-500/10 text-amber-400 ring-1 ring-amber-500/20',   dot:'bg-amber-400',   desc:'Node is at capacity. New server creation blocked.' },
      down:    { label:'Down',     cls:'bg-red-500/10 text-red-400 ring-1 ring-red-500/20',         dot:'bg-red-400',     desc:'Node is unavailable. All creation blocked.' },
      premium: { label:'Premium',  cls:'bg-blue-500/10 text-blue-400 ring-1 ring-blue-500/20',      dot:'bg-blue-400',    desc:'Paid subscribers only. Instant creation, no queue.' },
    };
  %>

  <!-- State legend -->
  <div class="px-4 sm:px-6 lg:px-8 pt-5">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
      <% Object.entries(stateInfo).forEach(([key, info]) => { %>
      <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] p-3">
        <div class="flex items-center gap-x-2 mb-1">
          <span class="h-1.5 w-1.5 rounded-full shrink-0 <%= info.dot %>"></span>
          <span class="text-xs font-semibold text-white"><%= info.label %></span>
        </div>
        <p class="text-[11px] text-zinc-500 leading-relaxed"><%= info.desc %></p>
      </div>
      <% }) %>
    </div>
  </div>

  <div class="px-4 sm:px-6 lg:px-8 pb-20 space-y-4">

    <% if (!nodes.length) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-16 text-center">
      <svg class="mx-auto h-10 w-10 text-zinc-700 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 0 0 3 3h7.5a3 3 0 0 0 3-3m-13.5 0V8.25m0 0a3 3 0 0 1 3-3h7.5a3 3 0 0 1 3 3m0 0v6m0-6h-13.5"/></svg>
      <p class="text-sm text-zinc-500">No nodes found.</p>
      <p class="text-xs text-zinc-600 mt-1">Make sure your Pterodactyl API credentials are set in Settings, then refresh to sync.</p>
    </div>
    <% } %>

    <% nodes.forEach(node => {
      const si = stateInfo[node.state] || stateInfo.active;
      const capacityPct = node.max_servers > 0 ? Math.min(100, Math.round((node.server_count / node.max_servers) * 100)) : null;
      const barColor = capacityPct === null ? '#3b82f6' : capacityPct >= 100 ? '#ef4444' : capacityPct > 75 ? '#f59e0b' : '#3b82f6';
    %>
    <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
      <!-- Node header -->
      <div class="flex flex-wrap items-center gap-3 px-5 py-4 bg-white/[0.02] border-b border-white/[0.06]">
        <div class="h-9 w-9 rounded-lg bg-zinc-800 flex items-center justify-center shrink-0">
          <svg class="h-4.5 w-4.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 0 0 3 3h7.5a3 3 0 0 0 3-3m-13.5 0V8.25m0 0a3 3 0 0 1 3-3h7.5a3 3 0 0 1 3 3m0 0v6m0-6h-13.5"/></svg>
        </div>
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-x-2 flex-wrap">
            <p class="text-sm font-semibold text-white"><%= node.name %></p>
            <code class="text-xs text-zinc-600"><%= node.fqdn %></code>
            <span class="text-xs text-zinc-700">ID: <%= node.panel_node_id %></span>
          </div>
          <div class="flex items-center gap-x-3 mt-0.5">
            <span class="inline-flex items-center gap-x-1 rounded-full px-2 py-0.5 text-xs font-medium <%= si.cls %>">
              <span class="h-1 w-1 rounded-full shrink-0 <%= si.dot %>"></span>
              <%= si.label %>
            </span>
            <span class="text-xs text-zinc-500">
              <%= node.server_count %> server<%= node.server_count !== 1 ? 's' : '' %>
              <% if (node.max_servers > 0) { %> / <%= node.max_servers %> max<% } else { %> (unlimited)<% } %>
            </span>
          </div>
        </div>
        <% if (capacityPct !== null) { %>
        <div class="shrink-0 text-right">
          <p class="text-xs text-zinc-500 mb-1">Capacity</p>
          <div class="w-28 h-1.5 rounded-full bg-zinc-800">
            <div class="h-1.5 rounded-full transition-all" style="width:<%= capacityPct %>%; background:<%= barColor %>"></div>
          </div>
          <p class="text-[10px] text-zinc-600 mt-0.5 text-right"><%= capacityPct %>%</p>
        </div>
        <% } %>
      </div>

      <!-- Edit form -->
      <form action="/admin/nodes/<%= node.panel_node_id %>/update" method="POST" class="p-5">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">

          <!-- State selector -->
          <div>
            <label class="block text-xs text-zinc-500 mb-2">Node State</label>
            <div class="grid grid-cols-2 gap-2">
              <% ['active','full','down','premium'].forEach(s => {
                const sInfo = stateInfo[s];
              %>
              <label class="flex items-center gap-x-2 rounded-lg border p-2.5 cursor-pointer transition-colors
                <%= node.state === s ? 'border-blue-500/40 bg-blue-500/5' : 'border-white/[0.06] hover:border-white/[0.12]' %>">
                <input type="radio" name="state" value="<%= s %>" <%= node.state === s ? 'checked' : '' %>
                  class="text-blue-400 bg-zinc-800 border-zinc-600 focus:ring-blue-400">
                <div>
                  <p class="text-xs font-medium text-white"><%= sInfo.label %></p>
                </div>
              </label>
              <% }) %>
            </div>
          </div>

          <!-- Max servers -->
          <div>
            <label class="block text-xs text-zinc-500 mb-2">Max Servers</label>
            <input type="number" name="max_servers" value="<%= node.max_servers %>" min="0"
              class="block w-full rounded-lg border-none py-2.5 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            <p class="text-[11px] text-zinc-600 mt-1.5">Set to <code class="text-zinc-500">0</code> for unlimited. When the server count reaches this number, state auto-changes to <span class="text-amber-400">Full</span>.</p>
          </div>

          <!-- Info / state description -->
          <div class="rounded-xl bg-white/[0.02] border border-white/[0.06] p-3.5">
            <p class="text-[10px] font-semibold text-zinc-600 uppercase tracking-widest mb-2">State Guide</p>
            <% Object.entries(stateInfo).forEach(([k, info]) => { %>
            <div class="flex items-start gap-x-2 mb-1.5">
              <span class="h-1.5 w-1.5 rounded-full shrink-0 mt-1 <%= info.dot %>"></span>
              <p class="text-[11px] text-zinc-500"><span class="text-zinc-300 font-medium"><%= info.label %></span> — <%= info.desc %></p>
            </div>
            <% }) %>
          </div>

        </div>
        <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
          Save Node Settings
        </button>
      </form>
    </div>
    <% }) %>

  </div>
</div>
</body>
</html>
