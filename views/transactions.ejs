<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>
<div class="app-main">

  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-xs text-zinc-500"><a href="/admin" class="hover:text-zinc-300 transition-colors">Admin</a> <span class="text-zinc-700">/ Transactions</span></p>
      <p class="text-sm font-semibold text-white mt-0.5">Transactions</p>
    </div>
    <span class="text-xs text-zinc-600"><%= transactions.length %> shown (last 50)</span>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'txns' }) %>

  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-20">
    <div class="rounded-2xl border border-white/[0.06] overflow-x-auto">
      <table class="w-full text-left text-sm min-w-[640px]">
        <thead class="bg-white/[0.02] border-b border-white/[0.06]">
          <tr>
            <th class="py-3 pl-4 pr-6 text-xs font-semibold text-zinc-500">User</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Plan</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Gateway</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Amount</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Type</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Status</th>
            <th class="py-3 pr-4 text-xs font-semibold text-zinc-500">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/[0.04]">
          <% if (!transactions.length) { %>
          <tr><td colspan="7" class="py-8 text-center text-sm text-zinc-500">No transactions yet.</td></tr>
          <% } %>
          <% transactions.forEach(t => { %>
          <tr class="hover:bg-white/[0.015] transition-colors">
            <td class="py-3 pl-4 pr-6 text-zinc-300 text-xs"><%= t.username %></td>
            <td class="py-3 pr-6 text-zinc-400 capitalize text-xs"><%= t.plan_key %></td>
            <td class="py-3 pr-6 text-zinc-400 capitalize text-xs"><%= t.gateway %></td>
            <td class="py-3 pr-6 text-white text-xs font-medium"><%= t.currency==='INR'?'₹':'$' %><%= Number(t.amount).toFixed(2) %></td>
            <td class="py-3 pr-6 text-zinc-500 capitalize text-xs"><%= t.type %></td>
            <td class="py-3 pr-6 text-xs">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= t.status==='paid'?'bg-green-500/10 text-green-400 ring-1 ring-green-500/20':t.status==='failed'?'bg-red-500/10 text-red-400 ring-1 ring-red-500/20':'bg-zinc-500/10 text-zinc-400 ring-1 ring-zinc-500/20' %>">
                <%= t.status %>
              </span>
            </td>
            <td class="py-3 pr-4 text-zinc-600 text-xs"><%= new Date(t.created_at).toLocaleDateString('en-IN') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
</body>
</html>
