<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>
<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-xs text-zinc-500"><a href="/admin" class="hover:text-zinc-300 transition-colors">Admin</a> <span class="text-zinc-700">/ Servers</span></p>
      <p class="text-sm font-semibold text-white mt-0.5">Servers</p>
    </div>
    <span class="text-xs text-zinc-600"><%= servers.length %> server<%= servers.length !== 1 ? 's' : '' %></span>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'servers' }) %>

  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-20 space-y-3">
    <% if (!servers.length) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-12 text-center"><p class="text-sm text-zinc-500">No servers yet.</p></div>
    <% } %>
    <% servers.forEach(server => { %>
    <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
      <div class="flex flex-wrap items-center gap-3 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-white truncate"><%= server.name %></p>
          <p class="text-xs text-zinc-500"><%= server.username %> &middot; <%= server.email %> &middot;
            <span class="<%= server.plan==='free'?'text-zinc-400':'text-blue-400' %>"><%= server.plan %></span>
            <% if (server.subscription_active===1) { %><span class="text-green-400 ml-1">(sub active)</span><% } %>
          </p>
        </div>
        <form action="/admin/servers/<%= server.id %>/delete" method="POST" onsubmit="return confirm('Permanently delete this server?')">
          <button type="submit" class="rounded-full bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-500/20 hover:bg-red-500/15 transition-colors">Delete</button>
        </form>
      </div>
      <form action="/admin/servers/<%= server.id %>/specs" method="POST" class="p-5">
        <div class="grid grid-cols-2 sm:grid-cols-6 gap-3 mb-3">
          <% [['memory','RAM (MB)'],['disk','Disk (MB)'],['cpu','CPU (%)'],['ports','Ports'],['databases','DBs'],['backups','Backups']].forEach(([k,l]) => { %>
          <div>
            <label class="block text-xs text-zinc-500 mb-1"><%= l %></label>
            <input type="number" name="<%= k %>" value="<%= server[k] %>" min="<%= k==='ports'?1:0 %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm">
          </div>
          <% }) %>
        </div>
        <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Update Specs</button>
      </form>
    </div>
    <% }) %>
  </div>
</div>
</body>
</html>
