<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>

<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <!-- Header + stats row -->
  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-sm font-semibold text-white">Admin Panel</p>
      <p class="text-xs text-zinc-500 mt-0.5">
        <span class="text-zinc-300"><%= userCount %></span> users &nbsp;·&nbsp;
        <span class="text-zinc-300"><%= serverCount %></span> servers &nbsp;·&nbsp;
        <span class="text-zinc-300"><%= paidTxnCount %></span> paid txns
      </p>
    </div>
    <form action="/admin/update" method="POST">
      <button type="submit" class="rounded-full bg-zinc-700/50 px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700 transition-colors">
        ↑ Check for Updates
      </button>
    </form>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'settings' }) %>

  <!-- Settings -->
  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-20 space-y-6">
    <form action="/admin/settings/defaults" method="POST" class="space-y-6">
      <input type="hidden" name="redirect" value="/admin">

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('gift', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white">Default Resource Pool</p>
          <p class="text-xs text-zinc-500 ml-1">— given to every new user on first login</p>
        </div>
        <div class="p-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          <% [['default_memory','RAM (MB)'],['default_disk','Disk (MB)'],['default_cpu','CPU (%)'],
              ['default_ports','Ports'],['default_databases','Databases'],['default_backups','Backups']].forEach(([k,l]) => { %>
          <div>
            <label class="block text-xs text-zinc-500 mb-1"><%= l %></label>
            <input type="number" name="<%= k %>" value="<%= settings[k] || '' %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <% }) %>
        </div>
      </div>

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('coin', 'h-4 w-4 text-yellow-400') %>
          <p class="text-sm font-semibold text-white">Coin Settings</p>
        </div>
        <div class="p-5 grid grid-cols-2 sm:grid-cols-4 gap-4">
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Daily Reward</label>
            <input type="number" name="daily_coins" value="<%= settings.daily_coins || 50 %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Work.ink Reward</label>
            <input type="number" name="workink_coins" value="<%= settings.workink_coins || 20 %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Paymentwall Reward</label>
            <input type="number" name="paymentwall_coins" value="<%= settings.paymentwall_coins || 30 %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Notik Reward</label>
            <input type="number" name="notik_coins" value="<%= settings.notik_coins || 25 %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('globe', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white">General & Branding</p>
          <span class="ml-auto inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
            <%= settings.hide_credit === '1' ? 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' : 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' %>">
            Dashboard Credit: <%= settings.hide_credit === '1' ? 'Hidden' : 'Shown' %>
          </span>
        </div>
        <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs text-zinc-500 mb-1">App Name <span class="text-zinc-600">(shown in sidebar, page titles, login)</span></label>
            <input type="text" name="app_name" value="<%= settings.app_name || 'FusionDash' %>" placeholder="FusionDash"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Favicon URL <span class="text-zinc-600">(leave blank for default letter icon)</span></label>
            <input type="text" name="app_favicon_url" value="<%= settings.app_favicon_url || '' %>" placeholder="https://example.com/icon.png"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Dashboard URL <span class="text-zinc-600">(used in server description)</span></label>
            <input type="text" name="dashboard_url" value="<%= settings.dashboard_url || '' %>" placeholder="https://your-domain.com"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
          </div>
          <div class="sm:col-span-2">
            <label class="flex items-center gap-x-3 cursor-pointer select-none">
              <div class="relative">
                <input type="checkbox" name="hide_credit" value="1" id="hideCreditToggle"
                  <%= settings.hide_credit === '1' ? 'checked' : '' %>
                  class="sr-only peer">
                <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
              </div>
              <span class="text-sm text-zinc-300">Dashboard Credit <span class="text-zinc-600">— disable to hide FusionDash promo/GitHub links; homepage "View source" becomes "View Plans" (<a href="/plans" target="_blank" class="text-blue-400 hover:underline">/plans</a>)</span></span>
            </label>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('refresh', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white">Server Renewal</p>
          <span class="ml-auto inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
            <%= settings.renewal_enabled === '1' ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
            <%= settings.renewal_enabled === '1' ? 'Enabled' : 'Disabled' %>
          </span>
        </div>
        <div class="p-5">
          <p class="text-xs text-zinc-500 mb-4">
            When enabled, users must renew servers with coins every N days or they get suspended for a grace period then permanently deleted.
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div class="col-span-2 sm:col-span-4">
              <label class="flex items-center gap-x-3 cursor-pointer select-none">
                <div class="relative">
                  <input type="checkbox" name="renewal_enabled" value="1" id="renewalToggle"
                    <%= settings.renewal_enabled === '1' ? 'checked' : '' %>
                    class="sr-only peer">
                  <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                  <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                </div>
                <span class="text-sm text-zinc-300">Enable renewal system</span>
              </label>
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Renewal price (coins)</label>
              <input type="number" name="renewal_price" value="<%= settings.renewal_price || 5 %>" min="0"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Renewal period (days)</label>
              <input type="number" name="renewal_days" value="<%= settings.renewal_days || 30 %>" min="1"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Grace period (days before delete)</label>
              <input type="number" name="renewal_grace_days" value="<%= settings.renewal_grace_days || 1 %>" min="0"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
          </div>
          <p class="mt-3 text-xs text-zinc-600">
            Cron job to process renewals every 30 min:
            <code class="text-zinc-500 ml-1">*/30 * * * * curl -sX POST http://localhost:3000/internal/process-renewals</code>
          </p>
        </div>
      </div>

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('list', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white">Server Creation Queue</p>
          <span class="ml-auto inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
            <%= settings.queue_enabled !== '0' ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
            <%= settings.queue_enabled !== '0' ? 'Enabled' : 'Disabled' %>
          </span>
        </div>
        <div class="p-5">
          <p class="text-xs text-zinc-500 mb-4">
            Controls how fast servers are created. Use the delay to prevent overloading a node when many users sign up at once.
            10 users × 2 min delay = servers ready within 20 minutes.
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div class="sm:col-span-3">
              <label class="flex items-center gap-x-3 cursor-pointer select-none">
                <div class="relative">
                  <input type="checkbox" name="queue_enabled" value="1" id="queueToggle"
                    <%= settings.queue_enabled !== '0' ? 'checked' : '' %>
                    class="sr-only peer">
                  <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                  <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                </div>
                <span class="text-sm text-zinc-300">Enable queue</span>
              </label>
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Delay between jobs (seconds)</label>
              <input type="number" name="queue_delay_seconds" value="<%= settings.queue_delay_seconds || 120 %>" min="0"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
              <p class="text-xs text-zinc-700 mt-1">120 = 2 min between each job</p>
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Max parallel creates</label>
              <input type="number" name="queue_max_parallel" value="<%= settings.queue_max_parallel || 1 %>" min="1" max="10"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
              <p class="text-xs text-zinc-700 mt-1">Keep at 1 unless your node is powerful</p>
            </div>
            <div class="flex items-end">
              <div class="rounded-xl bg-zinc-900/60 border border-white/[0.04] px-4 py-3 w-full">
                <p class="text-xs text-zinc-500 mb-1">ETA for 10 users (calculated)</p>
                <p class="text-sm font-semibold text-white" id="etaPreview">—</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('money', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white">Live Platform Stats</p>
          <p class="text-xs text-zinc-500 ml-1">— shown on the public home page</p>
        </div>
        <div class="p-5 grid grid-cols-2 sm:grid-cols-3 gap-4">
          <% [
            ['stat_show_users','Registered users'],
            ['stat_show_servers','Servers created'],
            ['stat_show_paid_transactions','Paid orders'],
            ['stat_show_free_servers','Free servers active'],
            ['stat_show_paid_servers','Paid plan servers'],
            ['stat_show_admins','Admins'],
            ['stat_show_revenue','Total revenue'],
          ].forEach(([k,l]) => { %>
          <label class="flex items-center gap-x-3 cursor-pointer select-none">
            <div class="relative">
              <input type="checkbox" name="<%= k %>" value="1"
                <%= settings[k] !== '0' ? 'checked' : '' %>
                class="sr-only peer">
              <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
              <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
            </div>
            <span class="text-sm text-zinc-300"><%= l %></span>
          </label>
          <% }) %>
        </div>
      </div>

      <button type="submit" class="rounded-full bg-blue-500/15 px-6 py-2 text-sm font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
        Save Settings
      </button>
    </form>
  </div>
</div>

<script>
  function updateEta() {
    const delay = parseInt(document.querySelector('[name=queue_delay_seconds]')?.value || '120', 10);
    const parallel = Math.max(1, parseInt(document.querySelector('[name=queue_max_parallel]')?.value || '1', 10));
    const users = 10;
    const totalSeconds = Math.ceil(users / parallel) * delay;
    const mins = Math.floor(totalSeconds / 60);
    const secs = totalSeconds % 60;
    const el = document.getElementById('etaPreview');
    if (el) el.textContent = mins > 0 ? `~${mins}m ${secs > 0 ? secs + 's' : ''}` : `~${secs}s`;
  }
  document.addEventListener('input', updateEta);
  setTimeout(updateEta, 200);
</script>
</body>
</html>
