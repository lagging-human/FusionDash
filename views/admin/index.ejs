<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>

<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <!-- Header + stats row -->
  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-sm font-semibold text-white">Admin Panel</p>
      <p class="text-xs text-zinc-500 mt-0.5">
        <span class="text-zinc-300"><%= users.length %></span> users &nbsp;├В┬╖&nbsp;
        <span class="text-zinc-300"><%= servers.length %></span> servers &nbsp;├В┬╖&nbsp;
        <span class="text-zinc-300"><%= transactions.filter(t=>t.status==='paid').length %></span> paid txns
      </p>
    </div>
    <form action="/admin/update" method="POST">
      <button type="submit" class="rounded-full bg-zinc-700/50 px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700 transition-colors">
        ├втАатАШ Check for Updates
      </button>
    </form>
  </div>

  <!-- Tab bar -->
  <div class="sticky top-0 z-10 flex overflow-x-auto gap-x-0.5 px-4 sm:px-6 lg:px-8 bg-[#0c0d0f] border-b border-white/[0.06]" id="tabBar">
    <% const tabs = [
      { id:'settings', label:'Settings',    iconName:'settings'  },
      { id:'apis',     label:'Earn APIs',   iconName:'link'  },
      { id:'plans',    label:'Plans',       iconName:'money'  },
      { id:'store',    label:'Store Items', iconName:'cart'  },
      { id:'servers',  label:'Servers',     iconName:'server'  },
      { id:'users',    label:'Users',       iconName:'users'  },
      { id:'txns',     label:'Transactions',iconName:'list'  },
    ]; %>
    <% tabs.forEach((tab, i) => { %>
    <button
      onclick="switchTab('<%= tab.id %>')"
      id="tab-btn-<%= tab.id %>"
      class="tab-btn shrink-0 flex items-center gap-x-1.5 px-4 py-3 text-xs font-semibold border-b-2 transition-colors whitespace-nowrap
        <%= i === 0 ? 'border-blue-400 text-white' : 'border-transparent text-zinc-500 hover:text-zinc-300 hover:border-zinc-600' %>">
      <%- icon(tab.iconName, 'h-3.5 w-3.5') %> <%= tab.label %>
    </button>
    <% }) %>
  </div>

  <!-- Tab panels -->
  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-20">

    <!-- ├втАЭтВм├втАЭтВм SETTINGS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-settings" class="tab-panel space-y-6">
      <form action="/admin/settings/defaults" method="POST" class="space-y-6">

        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('gift', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Default Resource Pool</p>
            <p class="text-xs text-zinc-500 ml-1">├втВмтАЭ given to every new user on first login</p>
          </div>
          <div class="p-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
            <% [['default_memory','RAM (MB)'],['default_disk','Disk (MB)'],['default_cpu','CPU (%)'],
                ['default_ports','Ports'],['default_databases','Databases'],['default_backups','Backups']].forEach(([k,l]) => { %>
            <div>
              <label class="block text-xs text-zinc-500 mb-1"><%= l %></label>
              <input type="number" name="<%= k %>" value="<%= settings[k] || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <% }) %>
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('coin', 'h-4 w-4 text-yellow-400') %>
            <p class="text-sm font-semibold text-white">Coin Settings</p>
          </div>
          <div class="p-5 grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Daily Reward</label>
              <input type="number" name="daily_coins" value="<%= settings.daily_coins || 50 %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Work.ink Reward</label>
              <input type="number" name="workink_coins" value="<%= settings.workink_coins || 20 %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Paymentwall Reward</label>
              <input type="number" name="paymentwall_coins" value="<%= settings.paymentwall_coins || 30 %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Notik Reward</label>
              <input type="number" name="notik_coins" value="<%= settings.notik_coins || 25 %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('globe', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">General & Branding</p>
          </div>
          <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">App Name <span class="text-zinc-600">(shown in sidebar, page titles, login)</span></label>
              <input type="text" name="app_name" value="<%= settings.app_name || 'FusionDash' %>" placeholder="FusionDash"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Favicon URL <span class="text-zinc-600">(leave blank for default letter icon)</span></label>
              <input type="text" name="app_favicon_url" value="<%= settings.app_favicon_url || '' %>" placeholder="https://example.com/icon.png"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Dashboard URL <span class="text-zinc-600">(used in server description)</span></label>
              <input type="text" name="dashboard_url" value="<%= settings.dashboard_url || '' %>" placeholder="https://your-domain.com"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('refresh', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Server Renewal</p>
            <span class="ml-auto inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= settings.renewal_enabled === '1' ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
              <%= settings.renewal_enabled === '1' ? 'Enabled' : 'Disabled' %>
            </span>
          </div>
          <div class="p-5">
            <p class="text-xs text-zinc-500 mb-4">
              When enabled, users must renew servers with coins every N days or they get suspended for a grace period then permanently deleted.
            </p>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
              <div class="col-span-2 sm:col-span-4">
                <label class="flex items-center gap-x-3 cursor-pointer select-none">
                  <div class="relative">
                    <input type="checkbox" name="renewal_enabled" value="1" id="renewalToggle"
                      <%= settings.renewal_enabled === '1' ? 'checked' : '' %>
                      class="sr-only peer">
                    <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                    <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                  </div>
                  <span class="text-sm text-zinc-300">Enable renewal system</span>
                </label>
              </div>
              <div>
                <label class="block text-xs text-zinc-500 mb-1">Renewal price (coins)</label>
                <input type="number" name="renewal_price" value="<%= settings.renewal_price || 5 %>" min="0"
                  class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
              </div>
              <div>
                <label class="block text-xs text-zinc-500 mb-1">Renewal period (days)</label>
                <input type="number" name="renewal_days" value="<%= settings.renewal_days || 30 %>" min="1"
                  class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
              </div>
              <div>
                <label class="block text-xs text-zinc-500 mb-1">Grace period (days before delete)</label>
                <input type="number" name="renewal_grace_days" value="<%= settings.renewal_grace_days || 1 %>" min="0"
                  class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
              </div>
            </div>
            <p class="mt-3 text-xs text-zinc-600">
              Cron job to process renewals every 30 min:
              <code class="text-zinc-500 ml-1">*/30 * * * * curl -sX POST http://localhost:3000/internal/process-renewals</code>
            </p>
          </div>
        </div>

        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('list', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Server Creation Queue</p>
            <span class="ml-auto inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
              <%= settings.queue_enabled !== '0' ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
              <%= settings.queue_enabled !== '0' ? 'Enabled' : 'Disabled' %>
            </span>
          </div>
          <div class="p-5">
            <p class="text-xs text-zinc-500 mb-4">
              Controls how fast servers are created. Use the delay to prevent overloading a node when many users sign up at once.
              10 users ├ГтАФ 2 min delay = servers ready within 20 minutes.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="sm:col-span-3">
                <label class="flex items-center gap-x-3 cursor-pointer select-none">
                  <div class="relative">
                    <input type="checkbox" name="queue_enabled" value="1" id="queueToggle"
                      <%= settings.queue_enabled !== '0' ? 'checked' : '' %>
                      class="sr-only peer">
                    <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
                    <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
                  </div>
                  <span class="text-sm text-zinc-300">Enable queue</span>
                </label>
              </div>
              <div>
                <label class="block text-xs text-zinc-500 mb-1">Delay between jobs (seconds)</label>
                <input type="number" name="queue_delay_seconds" value="<%= settings.queue_delay_seconds || 120 %>" min="0"
                  class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
                <p class="text-xs text-zinc-700 mt-1">120 = 2 min between each job</p>
              </div>
              <div>
                <label class="block text-xs text-zinc-500 mb-1">Max parallel creates</label>
                <input type="number" name="queue_max_parallel" value="<%= settings.queue_max_parallel || 1 %>" min="1" max="10"
                  class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
                <p class="text-xs text-zinc-700 mt-1">Keep at 1 unless your node is powerful</p>
              </div>
              <div class="flex items-end">
                <div class="rounded-xl bg-zinc-900/60 border border-white/[0.04] px-4 py-3 w-full">
                  <p class="text-xs text-zinc-500 mb-1">ETA for 10 users (calculated)</p>
                  <p class="text-sm font-semibold text-white" id="etaPreview">├втВмтАЭ</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <button type="submit" class="rounded-full bg-blue-500/15 px-6 py-2 text-sm font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
          Save Settings
        </button>
      </form>
    </div>

    <!-- ├втАЭтВм├втАЭтВм EARN APIs ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-apis" class="tab-panel hidden space-y-4">
      <form action="/admin/settings/defaults" method="POST" class="space-y-4">

        <!-- Work.ink -->
        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('link', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Work.ink</p>
            <a href="https://work.ink/developers" target="_blank" class="ml-auto text-xs text-blue-400 hover:underline">Docs ├втАатАЩ</a>
          </div>
          <div class="p-5 grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">API Key / Secret (sent as <code>secret</code> param)</label>
              <input type="text" name="workink_api_key" value="<%= settings.workink_api_key || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm font-mono" placeholder="sk_...">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Offer / Locker ID (slug in work.ink/<strong>ID</strong>)</label>
              <input type="text" name="workink_offer_id" value="<%= settings.workink_offer_id || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm" placeholder="abc123">
            </div>
          </div>
          <div class="px-5 pb-4 text-xs text-zinc-600">
            Postback URL to set in Work.ink dashboard:
            <code class="text-zinc-400 ml-1"><%= settings.dashboard_url || 'https://yourdomain.com' %>/earn/workink/callback?user_id={user_id}&offer_id={offer_id}&payout={payout}&secret=<%= settings.workink_api_key || 'YOUR_KEY' %></code>
          </div>
        </div>

        <!-- Paymentwall -->
        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('card', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Paymentwall Offerwall</p>
            <a href="https://docs.paymentwall.com/integration/widget/offerwall" target="_blank" class="ml-auto text-xs text-blue-400 hover:underline">Docs ├втАатАЩ</a>
          </div>
          <div class="p-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">App Key (Public)</label>
              <input type="text" name="paymentwall_app_key" value="<%= settings.paymentwall_app_key || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm font-mono" placeholder="t_...">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Secret Key</label>
              <input type="text" name="paymentwall_secret_key" value="<%= settings.paymentwall_secret_key || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm font-mono" placeholder="t_...">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Widget Code</label>
              <select name="paymentwall_widget" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
                <option value="mw6" <%= settings.paymentwall_widget==='mw6'?'selected':'' %>>mw6 (new)</option>
                <option value="mw1" <%= settings.paymentwall_widget==='mw1'?'selected':'' %>>mw1 (classic)</option>
              </select>
            </div>
          </div>
          <div class="px-5 pb-4 text-xs text-zinc-600">
            Pingback URL to set in Paymentwall dashboard:
            <code class="text-zinc-400 ml-1"><%= settings.dashboard_url || 'https://yourdomain.com' %>/earn/paymentwall/callback</code>
          </div>
        </div>

        <!-- Notik -->
        <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
          <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
            <%- icon('bolt', 'h-4 w-4 text-zinc-400') %>
            <p class="text-sm font-semibold text-white">Notik</p>
            <a href="https://notik.me" target="_blank" class="ml-auto text-xs text-blue-400 hover:underline">Dashboard ├втАатАЩ</a>
          </div>
          <div class="p-5 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">API Key</label>
              <input type="text" name="notik_api_key" value="<%= settings.notik_api_key || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm font-mono" placeholder="nk_...">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Secret Key (for postback validation)</label>
              <input type="text" name="notik_secret_key" value="<%= settings.notik_secret_key || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm font-mono" placeholder="sk_...">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Offer Wall URL (from Notik dashboard)</label>
              <input type="text" name="notik_offer_url" value="<%= settings.notik_offer_url || '' %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm" placeholder="https://notik.me/offers?api_key=...">
            </div>
          </div>
          <div class="px-5 pb-4 text-xs text-zinc-600">
            Postback URL to set in Notik dashboard:
            <code class="text-zinc-400 ml-1"><%= settings.dashboard_url || 'https://yourdomain.com' %>/earn/notik/callback?user_id={user_id}&offer_id={offer_id}&payout={payout}&secret=<%= settings.notik_secret_key || 'YOUR_SECRET' %></code>
          </div>
        </div>

        <button type="submit" class="rounded-full bg-blue-500/15 px-6 py-2 text-sm font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
          Save API Settings
        </button>
      </form>
    </div>

    <!-- ├втАЭтВм├втАЭтВм PLANS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-plans" class="tab-panel hidden space-y-4">
      <% plans.forEach(plan => { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <p class="text-sm font-semibold text-white capitalize"><%= plan.name %></p>
          <code class="text-xs text-zinc-500 ml-1"><%= plan.key %></code>
          <span class="ml-auto inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
            <%= plan.active ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
            <%= plan.active ? 'Active' : 'Inactive' %>
          </span>
        </div>
        <form action="/admin/plans/<%= plan.key %>" method="POST" class="p-5">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-3">
            <% [['name','Name','text'],['price_inr','Price INR (paise)','number'],['price_usd','Price USD','number'],['memory','RAM (MB)','number'],['disk','Disk (MB)','number'],['cpu','CPU (%)','number'],['databases','Databases','number'],['backups','Backups','number']].forEach(([k,l,t]) => { %>
            <div>
              <label class="block text-xs text-zinc-500 mb-1"><%= l %></label>
              <input type="<%= t %>" name="<%= k %>" value="<%= plan[k] %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700/80 focus:ring-blue-400 text-sm">
            </div>
            <% }) %>
          </div>
          <div class="flex items-center gap-x-4">
            <label class="flex items-center gap-x-2 text-sm text-zinc-400 cursor-pointer select-none">
              <input type="checkbox" name="active" <%= plan.active ? 'checked' : '' %> class="rounded bg-zinc-700 border-zinc-600 text-blue-400">
              Active
            </label>
            <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Save</button>
          </div>
        </form>
      </div>
      <% }) %>
    </div>

    <!-- ├втАЭтВм├втАЭтВм STORE ITEMS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-store" class="tab-panel hidden space-y-4">
      <!-- Add new item -->
      <div class="rounded-2xl border border-blue-500/20 bg-blue-500/5 overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 border-b border-blue-500/20">
          <%- icon('plus', 'h-4 w-4 text-blue-400') %>
          <p class="text-sm font-semibold text-white">Add New Item</p>
        </div>
        <form action="/admin/store/new" method="POST" class="p-5">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-3">
            <div><label class="block text-xs text-zinc-500 mb-1">Key (unique)</label><input type="text" name="key" placeholder="ram_4gb" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Name</label><input type="text" name="name" placeholder="4 GB RAM" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Resource</label>
              <select name="resource" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
                <option>memory</option><option>disk</option><option>cpu</option><option>ports</option><option>databases</option><option>backups</option><option>coins</option>
              </select>
            </div>
            <div><label class="block text-xs text-zinc-500 mb-1">Amount</label><input type="number" name="amount" placeholder="4096" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Cost (coins)</label><input type="number" name="cost" placeholder="25" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Description</label><input type="text" name="description" placeholder="Add 4 GB RAM" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
          </div>
          <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Create Item</button>
        </form>
      </div>

      <% storeItems.forEach(item => { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <p class="text-sm font-semibold text-white"><%= item.name %></p>
          <code class="text-xs text-zinc-600 ml-1"><%= item.key %></code>
          <span class="ml-auto inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
            <%= item.active ? 'bg-green-500/10 text-green-400' : 'bg-zinc-500/10 text-zinc-500' %>">
            <%= item.active ? 'Active' : 'Inactive' %>
          </span>
        </div>
        <form action="/admin/store/<%= item.key %>" method="POST" class="p-5">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-3">
            <div><label class="block text-xs text-zinc-500 mb-1">Name</label><input type="text" name="name" value="<%= item.name %>" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Description</label><input type="text" name="description" value="<%= item.description %>" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Resource</label><input type="text" name="resource" value="<%= item.resource %>" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Amount</label><input type="number" name="amount" value="<%= item.amount %>" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
            <div><label class="block text-xs text-zinc-500 mb-1">Cost (coins)</label><input type="number" name="cost" value="<%= item.cost %>" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm"></div>
          </div>
          <div class="flex items-center gap-x-4">
            <label class="flex items-center gap-x-2 text-sm text-zinc-400 cursor-pointer select-none">
              <input type="checkbox" name="active" <%= item.active ? 'checked' : '' %> class="rounded bg-zinc-700 border-zinc-600 text-blue-400">
              Active
            </label>
            <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Save</button>
          </div>
        </form>
      </div>
      <% }) %>
    </div>

    <!-- ├втАЭтВм├втАЭтВм SERVERS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-servers" class="tab-panel hidden space-y-3">
      <% if (!servers.length) { %>
      <div class="rounded-2xl border border-dashed border-white/10 py-12 text-center"><p class="text-sm text-zinc-500">No servers yet.</p></div>
      <% } %>
      <% servers.forEach(server => { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex flex-wrap items-center gap-3 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-white truncate"><%= server.name %></p>
            <p class="text-xs text-zinc-500"><%= server.username %> &middot; <%= server.email %> &middot;
              <span class="<%= server.plan==='free'?'text-zinc-400':'text-blue-400' %>"><%= server.plan %></span>
              <% if (server.subscription_active===1) { %><span class="text-green-400 ml-1">(sub active)</span><% } %>
            </p>
          </div>
          <form action="/admin/servers/<%= server.id %>/delete" method="POST" onsubmit="return confirm('Permanently delete this server?')">
            <button type="submit" class="rounded-full bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-500/20 hover:bg-red-500/15 transition-colors">Delete</button>
          </form>
        </div>
        <form action="/admin/servers/<%= server.id %>/specs" method="POST" class="p-5">
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-3">
            <% [['memory','RAM (MB)'],['disk','Disk (MB)'],['cpu','CPU (%)'],['databases','DBs'],['backups','Backups']].forEach(([k,l]) => { %>
            <div>
              <label class="block text-xs text-zinc-500 mb-1"><%= l %></label>
              <input type="number" name="<%= k %>" value="<%= server[k] %>"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm">
            </div>
            <% }) %>
          </div>
          <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Update Specs</button>
        </form>
      </div>
      <% }) %>
    </div>

    <!-- ├втАЭтВм├втАЭтВм USERS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-users" class="tab-panel hidden space-y-3">
      <% if (!users.length) { %>
      <div class="rounded-2xl border border-dashed border-white/10 py-12 text-center"><p class="text-sm text-zinc-500">No users yet.</p></div>
      <% } %>
      <% users.forEach(u => { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex flex-wrap items-center gap-3 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <% if (u.avatar) { %><img src="<%= u.avatar %>" class="h-8 w-8 rounded-full shrink-0" alt=""><% } else { %>
          <div class="h-8 w-8 rounded-full bg-zinc-700 flex items-center justify-center text-sm font-bold text-zinc-300 shrink-0"><%= u.username?u.username[0].toUpperCase():'?' %></div>
          <% } %>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-semibold text-white truncate"><%= u.username %> <% if (u.is_admin) { %><span class="ml-1 text-xs text-indigo-400">(admin)</span><% } %></p>
            <p class="text-xs text-zinc-500 truncate"><%= u.email %> &middot; via <%= u.provider %> &middot; Panel ID: <%= u.pterodactyl_user_id||'├втВмтАЭ' %></p>
          </div>
          <div class="flex items-center gap-x-1.5 text-sm text-yellow-400 shrink-0"><%- icon('coin', 'h-4 w-4') %> <span class="font-bold"><%= u.coins %></span></div>
        </div>
        <div class="p-5 space-y-4">
          <!-- Pool editor -->
          <div>
            <p class="text-xs text-zinc-500 mb-2">Resource Pool</p>
            <form action="/admin/users/<%= u.id %>/set-resources" method="POST" class="grid grid-cols-3 sm:grid-cols-6 gap-2">
              <% [['res_memory','RAM (MB)'],['res_disk','Disk (MB)'],['res_cpu','CPU (%)'],['res_ports','Ports'],['res_databases','DBs'],['res_backups','Backups']].forEach(([k,l]) => { %>
              <div>
                <label class="block text-[10px] text-zinc-600 mb-1"><%= l %></label>
                <input type="number" name="<%= k %>" value="<%= u[k] %>"
                  class="block w-full rounded-lg border-none py-1.5 pl-2 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-xs focus:ring-blue-400">
              </div>
              <% }) %>
              <div class="col-span-3 sm:col-span-6">
                <button type="submit" class="rounded-full bg-zinc-700/50 px-4 py-1.5 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700 transition-colors">Update Resources</button>
              </div>
            </form>
          </div>
          <!-- Coin gift + admin toggle -->
          <div class="flex flex-wrap items-center gap-x-3 gap-y-2 pt-3 border-t border-white/[0.04]">
            <form action="/admin/users/<%= u.id %>/gift-coins" method="POST" class="flex items-center gap-x-2">
              <input type="number" name="amount" value="100" min="1"
                class="w-20 rounded-lg border-none py-1.5 pl-2 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-xs focus:ring-yellow-400 text-center">
              <button type="submit" class="rounded-full bg-yellow-400/10 px-4 py-1.5 text-xs font-semibold text-yellow-400 ring-1 ring-inset ring-yellow-400/20 hover:bg-yellow-400/15 transition-colors">Gift Coins</button>
            </form>
            <form action="/admin/users/<%= u.id %>/toggle-admin" method="POST">
              <button type="submit" class="rounded-full bg-indigo-500/10 px-4 py-1.5 text-xs font-medium text-indigo-400 ring-1 ring-inset ring-indigo-500/20 hover:bg-indigo-500/15 transition-colors">
                <%= u.is_admin ? 'Revoke Admin' : 'Make Admin' %>
              </button>
            </form>
          </div>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- ├втАЭтВм├втАЭтВм TRANSACTIONS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-txns" class="tab-panel hidden">
      <div class="rounded-2xl border border-white/[0.06] overflow-x-auto">
        <table class="w-full text-left text-sm min-w-[640px]">
          <thead class="bg-white/[0.02] border-b border-white/[0.06]">
            <tr>
              <th class="py-3 pl-4 pr-6 text-xs font-semibold text-zinc-500">User</th>
              <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Plan</th>
              <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Gateway</th>
              <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Amount</th>
              <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Type</th>
              <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Status</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/[0.04]">
            <% if (!transactions.length) { %>
            <tr><td colspan="7" class="py-8 text-center text-sm text-zinc-500">No transactions yet.</td></tr>
            <% } %>
            <% transactions.forEach(t => { %>
            <tr class="hover:bg-white/[0.015] transition-colors">
              <td class="py-3 pl-4 pr-6 text-zinc-300 text-xs"><%= t.username %></td>
              <td class="py-3 pr-6 text-zinc-400 capitalize text-xs"><%= t.plan_key %></td>
              <td class="py-3 pr-6 text-zinc-400 capitalize text-xs"><%= t.gateway %></td>
              <td class="py-3 pr-6 text-white text-xs font-medium"><%= t.currency==='INR'?'├втАЪ┬╣':'$' %><%= Number(t.amount).toFixed(2) %></td>
              <td class="py-3 pr-6 text-zinc-500 capitalize text-xs"><%= t.type %></td>
              <td class="py-3 pr-6 text-xs">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                  <%= t.status==='paid'?'bg-green-500/10 text-green-400 ring-1 ring-green-500/20':t.status==='failed'?'bg-red-500/10 text-red-400 ring-1 ring-red-500/20':'bg-zinc-500/10 text-zinc-400 ring-1 ring-zinc-500/20' %>">
                  <%= t.status %>
                </span>
              </td>
              <td class="py-3 pr-4 text-zinc-600 text-xs"><%= new Date(t.created_at).toLocaleDateString('en-IN') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>


    <!-- ├втАЭтВм├втАЭтВм EGGS ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм -->
    <div id="tab-eggs" class="tab-panel hidden space-y-4">

      <!-- Sync from panel -->
      <div class="flex flex-wrap items-center justify-between gap-3 rounded-2xl border border-white/[0.06] bg-white/[0.02] px-5 py-4">
        <div>
          <p class="text-sm font-semibold text-white">Sync from Panel</p>
          <p class="text-xs text-zinc-500 mt-0.5">Pull all nests and eggs from your Pterodactyl panel into the list below.</p>
        </div>
        <form action="/admin/eggs/sync" method="POST">
          <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
            Sync from Panel
          </button>
        </form>
      </div>

      <!-- Add manually -->
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="flex items-center gap-x-2 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
          <%- icon('plus', 'h-4 w-4 text-blue-400') %>
          <p class="text-sm font-semibold text-white">Add Egg Manually</p>
        </div>
        <form action="/admin/eggs/add" method="POST" class="p-5">
          <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-3">
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Nest ID</label>
              <input type="number" name="nest_id" placeholder="1"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Egg ID</label>
              <input type="number" name="egg_id" placeholder="3"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Nest Name</label>
              <input type="text" name="nest_name" placeholder="Minecraft"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Egg Name</label>
              <input type="text" name="egg_name" placeholder="Paper" required
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
            </div>
            <div>
              <label class="block text-xs text-zinc-500 mb-1">Description</label>
              <input type="text" name="description" placeholder="Optional"
                class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
            </div>
          </div>
          <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Add Egg</button>
        </form>
      </div>

      <!-- Egg list -->
      <% if (!eggs.length) { %>
      <div class="rounded-2xl border border-dashed border-white/10 py-12 text-center">
        <p class="text-sm text-zinc-500">No eggs yet. Click "Sync from Panel" to import them.</p>
        <p class="text-xs text-zinc-600 mt-1">If no eggs are configured, users will see all eggs from the panel.</p>
      </div>
      <% } else { %>
      <%
        const nestGroups = {};
        eggs.forEach(e => {
          const k = e.nest_name || ('Nest ' + e.nest_id);
          if (!nestGroups[k]) nestGroups[k] = [];
          nestGroups[k].push(e);
        });
      %>
      <% Object.entries(nestGroups).forEach(([nestName, nestEggs]) => { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <div class="px-5 py-3 bg-white/[0.02] border-b border-white/[0.06] flex items-center gap-x-2">
          <%- icon('database', 'h-4 w-4 text-zinc-400') %>
          <p class="text-sm font-semibold text-white"><%= nestName %></p>
          <span class="text-xs text-zinc-600 ml-1"><%= nestEggs.length %> egg<%= nestEggs.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="divide-y divide-white/[0.04]">
          <% nestEggs.forEach(egg => { %>
          <div class="px-5 py-4 flex flex-wrap items-center gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-x-2">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                  <%= egg.active ? 'bg-green-500/10 text-green-400 ring-1 ring-green-500/20' : 'bg-zinc-500/10 text-zinc-500 ring-1 ring-zinc-500/20' %>">
                  <%= egg.active ? 'Enabled' : 'Disabled' %>
                </span>
                <p class="text-sm font-medium text-white"><%= egg.egg_name %></p>
                <span class="text-xs text-zinc-600">nest:<%= egg.nest_id %> egg:<%= egg.egg_id %></span>
              </div>
              <% if (egg.description) { %>
                <p class="text-xs text-zinc-500 mt-0.5"><%= egg.description %></p>
              <% } %>
            </div>
            <div class="flex items-center gap-x-2 shrink-0">
              <!-- Quick toggle -->
              <form action="/admin/eggs/<%= egg.id %>" method="POST" class="inline">
                <input type="hidden" name="egg_name" value="<%= egg.egg_name %>">
                <input type="hidden" name="nest_name" value="<%= egg.nest_name || '' %>">
                <input type="hidden" name="description" value="<%= egg.description || '' %>">
                <input type="hidden" name="active" value="<%= egg.active ? '0' : '1' %>">
                <button type="submit"
                  class="rounded-full px-4 py-1.5 text-xs font-medium ring-1 ring-inset transition-colors
                    <%= egg.active ? 'bg-amber-500/10 text-amber-400 ring-amber-500/20 hover:bg-amber-500/15' : 'bg-green-500/10 text-green-400 ring-green-500/20 hover:bg-green-500/15' %>">
                  <%= egg.active ? 'Disable' : 'Enable' %>
                </button>
              </form>
              <!-- Edit inline -->
              <button onclick="toggleEdit(<%= egg.id %>)"
                class="rounded-full bg-zinc-700/40 px-4 py-1.5 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700/60 transition-colors">
                Edit
              </button>
              <!-- Delete -->
              <form action="/admin/eggs/<%= egg.id %>/delete" method="POST" class="inline"
                onsubmit="return confirm('Delete egg <%= egg.egg_name %>?')">
                <button type="submit" class="rounded-full bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-500/20 hover:bg-red-500/15 transition-colors">
                  Delete
                </button>
              </form>
            </div>
            <!-- Inline edit form (hidden by default) -->
            <div id="edit-egg-<%= egg.id %>" class="hidden w-full mt-2 pt-3 border-t border-white/[0.04]">
              <form action="/admin/eggs/<%= egg.id %>" method="POST" class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                <div>
                  <label class="block text-xs text-zinc-500 mb-1">Egg Name</label>
                  <input type="text" name="egg_name" value="<%= egg.egg_name %>" required
                    class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
                </div>
                <div>
                  <label class="block text-xs text-zinc-500 mb-1">Nest Name</label>
                  <input type="text" name="nest_name" value="<%= egg.nest_name || '' %>"
                    class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
                </div>
                <div>
                  <label class="block text-xs text-zinc-500 mb-1">Description</label>
                  <input type="text" name="description" value="<%= egg.description || '' %>"
                    class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
                </div>
                <div class="flex items-end gap-x-2">
                  <label class="flex items-center gap-x-2 text-sm text-zinc-400 cursor-pointer mb-2">
                    <input type="checkbox" name="active" value="1" <%= egg.active ? 'checked' : '' %> class="rounded bg-zinc-700 border-zinc-600 text-blue-400">
                    Active
                  </label>
                  <button type="submit" class="mb-0.5 rounded-full bg-blue-500/15 px-4 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Save</button>
                </div>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
      <% } %>
    </div>

  </div><!-- /.tab panels -->
</div><!-- /.app-main -->

<script>
  const tabs = ['settings','apis','plans','store','servers','users','txns','eggs'];

  // Live ETA preview calculator in settings tab
  function toggleEdit(id) {
    const el = document.getElementById('edit-egg-' + id);
    el.classList.toggle('hidden');
  }

  function updateEta() {
    const delay = parseInt(document.querySelector('[name=queue_delay_seconds]')?.value || '120', 10);
    const parallel = Math.max(1, parseInt(document.querySelector('[name=queue_max_parallel]')?.value || '1', 10));
    const users = 10;
    const totalSeconds = Math.ceil(users / parallel) * delay;
    const mins = Math.floor(totalSeconds / 60);
    const secs = totalSeconds % 60;
    const el = document.getElementById('etaPreview');
    if (el) el.textContent = mins > 0 ? `~${mins}m ${secs > 0 ? secs + 's' : ''}` : `~${secs}s`;
  }
  document.addEventListener('input', updateEta);
  setTimeout(updateEta, 200);

  function switchTab(id) {
    // Restore from URL hash on load
    tabs.forEach(t => {
      document.getElementById('tab-'+t).classList.add('hidden');
      const btn = document.getElementById('tab-btn-'+t);
      btn.classList.remove('border-blue-400','text-white');
      btn.classList.add('border-transparent','text-zinc-500');
    });
    document.getElementById('tab-'+id).classList.remove('hidden');
    const active = document.getElementById('tab-btn-'+id);
    active.classList.add('border-blue-400','text-white');
    active.classList.remove('border-transparent','text-zinc-500');
    history.replaceState(null, '', '#' + id);
  }

  // Restore tab from URL hash
  const hash = location.hash.replace('#','');
  if (tabs.includes(hash)) switchTab(hash);
</script>
</body>
</html>
