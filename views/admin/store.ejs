<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'admin' }) %>
<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-xs text-zinc-500"><a href="/admin" class="hover:text-zinc-300 transition-colors">Admin</a> <span class="text-zinc-700">/ Store</span></p>
      <p class="text-sm font-semibold text-white mt-0.5">Store Items</p>
    </div>
    <span class="text-xs text-zinc-600"><%= storeItems.length %> item<%= storeItems.length !== 1 ? 's' : '' %></span>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'store' }) %>

  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-20 space-y-5">

    <!-- Create new item -->
    <div class="rounded-2xl border border-blue-500/20 bg-blue-500/5 overflow-hidden">
      <div class="flex items-center gap-x-2 px-5 py-3 border-b border-blue-500/20">
        <svg class="h-4 w-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        <p class="text-sm font-semibold text-white">Add New Item</p>
      </div>
      <form action="/admin/store/new" method="POST" class="p-5">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-4">
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Key <span class="text-zinc-600">(unique)</span></label>
            <input type="text" name="key" placeholder="ram_4gb" required
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm font-mono">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Name</label>
            <input type="text" name="name" placeholder="4 GB RAM" required
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Resource</label>
            <select name="resource" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
              <option value="memory">memory</option>
              <option value="disk">disk</option>
              <option value="cpu">cpu</option>
              <option value="ports">ports</option>
              <option value="databases">databases</option>
              <option value="backups">backups</option>
              <option value="coins">coins</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Amount</label>
            <input type="number" name="amount" placeholder="4096"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Cost <span class="text-zinc-600">(coins)</span></label>
            <input type="number" name="cost" placeholder="25"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Description</label>
            <input type="text" name="description" placeholder="Add 4 GB RAM to pool"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
        </div>
        <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
          Create Item
        </button>
      </form>
    </div>

    <!-- Resource type badges for reference -->
    <div class="flex flex-wrap gap-2 px-1">
      <% const resColors = { memory:'bg-blue-500/10 text-blue-400', disk:'bg-violet-500/10 text-violet-400', cpu:'bg-orange-500/10 text-orange-400', ports:'bg-teal-500/10 text-teal-400', databases:'bg-pink-500/10 text-pink-400', backups:'bg-amber-500/10 text-amber-400', coins:'bg-yellow-400/10 text-yellow-400' }; %>
      <% Object.entries(resColors).forEach(([r, cls]) => { %>
      <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <%= cls %>"><%= r %></span>
      <% }) %>
    </div>

    <!-- Existing items -->
    <% if (!storeItems.length) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-12 text-center">
      <p class="text-sm text-zinc-500">No store items yet. Create one above.</p>
    </div>
    <% } %>

    <% storeItems.forEach(item => {
      const rColors = { memory:'text-blue-400', disk:'text-violet-400', cpu:'text-orange-400', ports:'text-teal-400', databases:'text-pink-400', backups:'text-amber-400', coins:'text-yellow-400' };
      const rColor = rColors[item.resource] || 'text-zinc-400';
    %>
    <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
      <div class="flex flex-wrap items-center gap-3 px-5 py-3 bg-white/[0.02] border-b border-white/[0.06]">
        <p class="text-sm font-semibold text-white"><%= item.name %></p>
        <code class="text-xs text-zinc-500 bg-zinc-900 rounded px-2 py-0.5"><%= item.key %></code>
        <span class="text-xs font-medium <%= rColor %>"><%= item.resource %></span>
        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
          <%= item.active ? 'bg-green-500/10 text-green-400' : 'bg-zinc-500/10 text-zinc-500' %>">
          <%= item.active ? 'Active' : 'Inactive' %>
        </span>
        <form action="/admin/store/<%= item.key %>/delete" method="POST" class="ml-auto"
          onsubmit="return confirm('Delete <%= item.name %>?')">
          <button type="submit" class="rounded-full bg-red-500/10 px-3 py-1 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-500/20 hover:bg-red-500/15 transition-colors">
            Delete
          </button>
        </form>
      </div>
      <form action="/admin/store/<%= item.key %>/update" method="POST" class="p-5">
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-4">
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Name</label>
            <input type="text" name="name" value="<%= item.name %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Description</label>
            <input type="text" name="description" value="<%= item.description || '' %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Resource</label>
            <select name="resource" class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
              <% ['memory','disk','cpu','ports','databases','backups','coins'].forEach(r => { %>
              <option value="<%= r %>" <%= item.resource===r?'selected':'' %>><%= r %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Amount</label>
            <input type="number" name="amount" value="<%= item.amount %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
          <div>
            <label class="block text-xs text-zinc-500 mb-1">Cost (coins)</label>
            <input type="number" name="cost" value="<%= item.cost %>"
              class="block w-full rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 focus:ring-blue-400 text-sm">
          </div>
        </div>
        <div class="flex items-center gap-x-4">
          <label class="flex items-center gap-x-3 cursor-pointer select-none">
            <div class="relative">
              <input type="checkbox" name="active" <%= item.active ? 'checked' : '' %> class="sr-only peer">
              <div class="w-10 h-5 bg-zinc-700 rounded-full peer peer-checked:bg-blue-500 transition-colors"></div>
              <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full transition-transform peer-checked:translate-x-5"></div>
            </div>
            <span class="text-sm text-zinc-300">Active</span>
          </label>
          <button type="submit" class="rounded-full bg-blue-500/15 px-5 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
            Save Changes
          </button>
        </div>
      </form>
    </div>
    <% }) %>

  </div>
</div>
</body>
</html>
