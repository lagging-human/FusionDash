<!-- Mobile overlay -->
<div id="sidebarOverlay" class="fixed inset-0 bg-black/60 z-30 hidden" onclick="closeSidebar()"></div>

<!-- Sidebar -->
<aside id="sidebar" class="fixed inset-y-0 left-0 z-40 w-64 bg-[#0c0d0f] border-r border-white/[0.06] flex flex-col"
  style="transition:transform .22s cubic-bezier(.4,0,.2,1); transform:translateX(-100%)">

  <!-- Logo -->
  <div class="flex items-center gap-x-3 px-5 py-4 border-b border-white/[0.06] shrink-0">
    <% if (appFavicon) { %>
      <img src="<%= appFavicon %>" class="h-8 w-8 rounded-lg object-cover shrink-0" alt="<%= appName %>">
    <% } else { %>
      <div class="h-8 w-8 rounded-lg bg-blue-500/20 flex items-center justify-center shrink-0">
        <span class="text-sm font-bold text-blue-400"><%= appName ? appName[0].toUpperCase() : 'F' %></span>
      </div>
    <% } %>
    <span class="font-semibold text-white text-sm tracking-tight"><%= appName %></span>
    <!-- Close button (mobile only) -->
    <button onclick="closeSidebar()" class="ml-auto text-zinc-500 hover:text-white lg:hidden">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- User pill -->
  <div class="px-3 py-3 border-b border-white/[0.06] shrink-0">
    <div class="flex items-center gap-x-3 rounded-xl bg-white/[0.04] px-3 py-2.5 ring-1 ring-inset ring-white/[0.06]">
      <% if (user && user.avatar) { %>
        <img src="<%= user.avatar %>" class="h-7 w-7 rounded-full shrink-0" alt="">
      <% } else { %>
        <div class="h-7 w-7 rounded-full bg-zinc-700 flex items-center justify-center text-xs text-zinc-300 font-semibold shrink-0">
          <%= user ? user.username[0].toUpperCase() : '?' %>
        </div>
      <% } %>
      <div class="min-w-0 flex-1">
        <p class="truncate text-xs font-semibold text-white"><%= user ? user.username : '' %></p>
        <p class="truncate text-xs text-zinc-500"><%= user && user.is_admin ? 'Administrator' : 'User' %></p>
      </div>
      <div class="shrink-0 flex items-center gap-x-1 text-xs text-yellow-400 font-medium">
        <%- icon('coin', 'h-3.5 w-3.5') %><span><%= typeof user !== 'undefined' && user ? user.coins : 0 %></span>
      </div>
    </div>
  </div>

  <!-- Nav (scrollable) -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-0.5">

    <!-- SERVERS -->
    <p class="px-2 pt-1 pb-2 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Servers</p>
    <a href="/dashboard" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
      Dashboard
    </a>
    <a href="/servers/create" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'create' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
      New Server
    </a>

    <!-- RESOURCES -->
    <p class="px-2 pt-4 pb-2 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Resources</p>
    <a href="/store" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'store' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 0 1 .75-.75h3a.75.75 0 0 1 .75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349M3.75 21V9.349m0 0a3.001 3.001 0 0 0 3.75-.615A2.993 2.993 0 0 0 9.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 0 0 2.25 1.016 2.993 2.993 0 0 0 2.25-1.016 3.001 3.001 0 0 0 3.75.614m-16.5 0a3.004 3.004 0 0 1-.621-4.72l1.189-1.19A1.5 1.5 0 0 1 5.378 3h13.243a1.5 1.5 0 0 1 1.06.44l1.19 1.189a3 3 0 0 1-.621 4.72M6.75 18h3.75a.75.75 0 0 0 .75-.75V13.5a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v3.75c0 .414.336.75.75.75Z"/></svg>
      Store
    </a>
    <a href="/earn" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'earn' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      Earn Coins
    </a>

    <!-- BILLING -->
    <p class="px-2 pt-4 pb-2 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Billing</p>
    <a href="/billing" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'billing' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 21Z"/></svg>
      Plans & Billing
    </a>

    <!-- ACCOUNT -->
    <p class="px-2 pt-4 pb-2 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Account</p>
    <a href="/account" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'account' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
      Account Settings
    </a>
    <a href="/account/reset-password" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'reset-password' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 0 1 21.75 8.25Z"/></svg>
      Panel Password
    </a>

    <!-- ADMIN (only if is_admin) -->
    <% if (user && user.is_admin) { %>
    <p class="px-2 pt-4 pb-2 text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Admin</p>
    <a href="/admin" class="nav-link nav-admin <%= typeof activePage !== 'undefined' && activePage === 'admin' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
      Admin Panel
    </a>
    <a href="/admin/audit" class="nav-link nav-admin <%= typeof activePage !== 'undefined' && activePage === 'audit' ? 'nav-active' : '' %>">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
      Audit Log
    </a>
    <% } %>

  </nav>

  <!-- Sign out -->
  <div class="px-3 py-3 border-t border-white/[0.06] shrink-0">
    <form action="/logout" method="POST">
      <button type="submit" class="w-full flex items-center gap-x-3 rounded-xl px-3 py-2 text-sm font-medium text-zinc-500 hover:bg-red-500/10 hover:text-red-400 transition-colors">
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/></svg>
        Sign out
      </button>
    </form>
  </div>
</aside>

<!-- Mobile top bar -->
<div class="lg:hidden fixed top-0 left-0 right-0 z-20 flex items-center justify-between px-4 py-3 bg-[#0c0d0f] border-b border-white/[0.06]">
  <button onclick="openSidebar()" class="p-1 rounded-lg text-zinc-400 hover:text-white hover:bg-white/5 transition-colors">
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
    </svg>
  </button>
  <span class="font-semibold text-white text-sm"><%= appName %></span>
  <a href="/account" class="p-1 rounded-lg text-zinc-400 hover:text-white hover:bg-white/5 transition-colors">
    <% if (user && user.avatar) { %>
      <img src="<%= user.avatar %>" class="h-6 w-6 rounded-full" alt="">
    <% } else { %>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
    <% } %>
  </a>
</div>

<style>
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-radius: 0.625rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #a1a1aa;
    text-decoration: none;
    transition: background-color .15s, color .15s;
  }
  .nav-link:hover { background: rgba(255,255,255,0.05); color: #fff; }
  .nav-active { background: rgba(255,255,255,0.07) !important; color: #fff !important; }
  .nav-admin:hover { background: rgba(99,102,241,0.12); color: #818cf8; }
  .nav-admin.nav-active { background: rgba(99,102,241,0.12) !important; color: #818cf8 !important; }
  .nav-icon { height: 1rem; width: 1rem; flex-shrink: 0; }

  /* Desktop: sidebar always visible */
  @media (min-width: 1024px) {
    #sidebar { transform: translateX(0) !important; }
    #sidebarOverlay { display: none !important; }
  }
</style>

<script>
  function openSidebar() {
    document.getElementById('sidebar').style.transform = 'translateX(0)';
    document.getElementById('sidebarOverlay').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar').style.transform = 'translateX(-100%)';
    document.getElementById('sidebarOverlay').classList.add('hidden');
    document.body.style.overflow = '';
  }
</script>
