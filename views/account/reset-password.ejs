<!doctype html>
<html class="h-full bg-[#0f1012]">
<%- include('../components/header') %>
<body class="h-full" style="font-family: 'Space Grotesk'">
<div>
  <%- include('../components/sidebar', { activePage: 'reset-password' }) %>
  <main class="lg:pl-64">

    <div class="flex items-center justify-between bg-zinc-700/10 border-b border-white/5 px-4 py-4 sm:px-6 lg:px-8">
      <div>
        <h1 class="text-base font-semibold text-white">Reset Panel Password</h1>
        <p class="mt-1 text-xs text-zinc-400">Generate a new password for your Pterodactyl panel account.</p>
      </div>
    </div>

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
        <p class="ml-3 text-sm text-amber-400"><%= error %></p>
      </div>
    </div>
    <% } %>

    <% if (newPassword) { %>
    <div class="border border-green-400/10 bg-green-400/5 p-4">
      <div class="flex">
        <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        <p class="ml-3 text-sm text-green-400">Password reset successfully.</p>
      </div>
    </div>
    <% } %>

    <div class="p-8 max-w-lg">
      <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6 mb-8">
        <p class="text-sm font-medium text-white mb-1">How it works</p>
        <p class="text-xs text-zinc-400 leading-5">
          Clicking the button below generates a new random password for your
          Pterodactyl panel account (<%= user.email %>). You'll be shown the new
          password once — copy it and use it to log in at
          <a href="<%= process.env.PTERODACTYL_PANEL_URL || '#' %>" target="_blank" class="text-blue-400 hover:underline"><%= process.env.PTERODACTYL_PANEL_URL || 'your panel' %></a>.
        </p>
        <% if (!user.pterodactyl_user_id) { %>
        <div class="mt-4 p-3 rounded-xl bg-amber-400/5 border border-amber-400/10">
          <p class="text-xs text-amber-400">Your account is not yet linked to the panel. Log out and back in to trigger linking.</p>
        </div>
        <% } %>
      </div>

      <% if (newPassword) { %>
      <div class="rounded-2xl bg-zinc-900 border border-white/10 p-5 mb-6">
        <p class="text-xs text-zinc-500 mb-2">Your new panel password — copy it now, it won't be shown again:</p>
        <div class="flex items-center gap-x-3">
          <code id="newPw" class="text-sm font-mono text-green-400 flex-1 break-all"><%= newPassword %></code>
          <button onclick="navigator.clipboard.writeText(document.getElementById('newPw').textContent)"
            class="shrink-0 rounded-lg bg-zinc-700/40 px-3 py-1.5 text-xs text-zinc-300 hover:bg-zinc-700/60 transition">
            Copy
          </button>
        </div>
      </div>
      <a href="<%= process.env.PTERODACTYL_PANEL_URL || '#' %>" target="_blank"
        class="inline-flex rounded-full bg-blue-400/10 px-6 py-2 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">
        Open Panel &rarr;
      </a>
      <% } else { %>
      <form action="/account/reset-password" method="POST">
        <button type="submit" <% if (!user.pterodactyl_user_id) { %>disabled<% } %>
          class="rounded-full bg-blue-400/10 px-6 py-2 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition disabled:opacity-40 disabled:cursor-not-allowed">
          Generate new password
        </button>
      </form>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
