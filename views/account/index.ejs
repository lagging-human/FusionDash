<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>

  <%- include('../components/sidebar', { activePage: 'account' }) %>
  <div class="app-main">

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-400"><%= error %></p>
    </div>
    <% } %>
    <% if (success) { %>
    <div class="border border-green-400/10 bg-green-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      <p class="text-sm text-green-400"><%= success %></p>
    </div>
    <% } %>

    <!-- Page header -->
    <div class="flex items-center justify-between bg-zinc-700/10 border-b border-white/5 px-4 py-4 sm:px-6 lg:px-8">
      <div>
        <h1 class="text-base font-semibold text-white">Account Settings</h1>
        <p class="mt-1 text-xs text-zinc-400">Manage your profile, subscriptions, and billing.</p>
      </div>
    </div>

    <div class="px-4 sm:px-6 lg:px-8 py-8 space-y-8 max-w-3xl">

      <!-- Profile card -->
      <div>
        <h2 class="text-sm font-semibold text-zinc-300 mb-3">Profile</h2>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6 flex items-center gap-x-5">
          <% if (user.avatar) { %>
            <img src="<%= user.avatar %>" class="h-16 w-16 rounded-full ring-2 ring-white/10" alt="">
          <% } else { %>
            <div class="h-16 w-16 rounded-full bg-zinc-700 flex items-center justify-center text-xl font-bold text-zinc-300">
              <%= user.username ? user.username[0].toUpperCase() : '?' %>
            </div>
          <% } %>
          <div class="flex-1 min-w-0">
            <p class="text-base font-semibold text-white truncate"><%= user.username %></p>
            <p class="text-sm text-zinc-400 truncate"><%= user.email || 'No email linked' %></p>
            <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-zinc-400/10 text-zinc-400 ring-1 ring-inset ring-zinc-400/20">
                via <%= user.provider %>
              </span>
              <% if (user.is_admin) { %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-blue-400/10 text-blue-400 ring-1 ring-inset ring-blue-400/20">
                Administrator
              </span>
              <% } %>
              <% if (user.pterodactyl_user_id) { %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-green-400/10 text-green-400 ring-1 ring-inset ring-green-400/20">
                Panel ID: <%= user.pterodactyl_user_id %>
              </span>
              <% } else { %>
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-amber-400/10 text-amber-400 ring-1 ring-inset ring-amber-400/20">
                Not linked to panel
              </span>
              <% } %>
            </div>
          </div>
          <a href="/account/reset-password" class="shrink-0 rounded-full bg-zinc-600/20 px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-600/30 transition">
            Reset Panel Password
          </a>
        </div>
      </div>

      <!-- Active Subscriptions -->
      <div>
        <h2 class="text-sm font-semibold text-zinc-300 mb-3">Subscriptions</h2>
        <% const paidServers = servers.filter(s => s.plan !== 'free'); %>
        <% if (paidServers.length === 0) { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6 text-center">
          <p class="text-sm text-zinc-500">No active subscriptions.</p>
          <a href="/dashboard#plans" class="mt-3 inline-block rounded-full bg-blue-400/10 px-4 py-1.5 text-xs font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">
            Browse Plans
          </a>
        </div>
        <% } else { %>
        <div class="space-y-3">
          <% paidServers.forEach(server => {
            const cycleEnd = server.billing_cycle_end ? new Date(server.billing_cycle_end) : null;
            const cycleStart = server.billing_cycle_start ? new Date(server.billing_cycle_start) : null;
            const daysLeft = cycleEnd ? Math.max(0, Math.ceil((cycleEnd - Date.now()) / 86400000)) : null;
            const subStatus = server.subscription_active === 1 ? 'active' : server.subscription_active === 2 ? 'cancelled' : 'inactive';
          %>
          <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-5">
            <div class="flex items-start justify-between gap-x-4">
              <div>
                <p class="text-sm font-medium text-white"><%= server.name %></p>
                <p class="text-xs text-zinc-500 mt-0.5 capitalize"><%= server.plan %> plan &middot; via <%= server.subscription_gateway || 'unknown' %></p>
              </div>
              <span class="shrink-0 inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium
                <%= subStatus === 'active' ? 'bg-green-400/10 text-green-400 ring-1 ring-green-400/20' : subStatus === 'cancelled' ? 'bg-amber-400/10 text-amber-400 ring-1 ring-amber-400/20' : 'bg-zinc-400/10 text-zinc-400 ring-1 ring-zinc-400/20' %>">
                <%= subStatus === 'active' ? 'Active' : subStatus === 'cancelled' ? 'Cancels at cycle end' : 'Inactive' %>
              </span>
            </div>

            <% if (cycleEnd) { %>
            <div class="mt-4">
              <div class="flex items-center justify-between text-xs text-zinc-500 mb-1">
                <span><%= cycleStart ? cycleStart.toLocaleDateString('en-IN') : '' %></span>
                <span><%= daysLeft %> days remaining</span>
                <span><%= cycleEnd.toLocaleDateString('en-IN') %></span>
              </div>
              <div class="h-1.5 w-full rounded-full bg-zinc-700/50">
                <% const total = cycleEnd - (cycleStart || cycleEnd - 30*86400000); const elapsed = Date.now() - (cycleStart || Date.now()); const pct = Math.min(100, Math.max(0, (elapsed/total)*100)); %>
                <div class="h-1.5 rounded-full <%= subStatus === 'cancelled' ? 'bg-amber-400/60' : 'bg-blue-400/60' %>" style="width:<%= pct.toFixed(1) %>%"></div>
              </div>
              <% if (subStatus === 'active') { %>
              <p class="text-xs text-zinc-500 mt-1.5">Renews on <%= cycleEnd.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
              <% } else if (subStatus === 'cancelled') { %>
              <p class="text-xs text-amber-400/70 mt-1.5">Expires on <%= cycleEnd.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %> — server will be suspended</p>
              <% } %>
            </div>
            <% } %>

            <% if (subStatus === 'active') { %>
            <form action="/servers/<%= server.id %>/cancel-subscription" method="POST" class="mt-4">
              <button type="submit" onclick="return confirm('Cancel subscription? Your server stays active until the billing cycle ends.')"
                class="rounded-full bg-red-400/5 px-4 py-1.5 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-400/10 hover:bg-red-400/10 transition">
                Cancel Subscription
              </button>
            </form>
            <% } %>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>

      <!-- Billing history -->
      <div>
        <h2 class="text-sm font-semibold text-zinc-300 mb-3">Billing History</h2>
        <% if (txns.length === 0) { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6 text-center">
          <p class="text-sm text-zinc-500">No transactions yet.</p>
        </div>
        <% } else { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 overflow-hidden">
          <table class="w-full text-left text-sm">
            <thead class="border-b border-white/5 text-xs text-zinc-500">
              <tr>
                <th class="py-3 pl-5 pr-4 font-medium">Date</th>
                <th class="py-3 pr-4 font-medium">Plan</th>
                <th class="py-3 pr-4 font-medium">Gateway</th>
                <th class="py-3 pr-4 font-medium">Amount</th>
                <th class="py-3 pr-5 font-medium text-right">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% txns.forEach(t => { %>
              <tr>
                <td class="py-3 pl-5 pr-4 text-zinc-400 text-xs"><%= new Date(t.created_at).toLocaleDateString('en-IN') %></td>
                <td class="py-3 pr-4 text-white capitalize"><%= t.plan_key %> <%= t.type === 'renewal' ? '(renewal)' : '' %></td>
                <td class="py-3 pr-4 text-zinc-400 capitalize"><%= t.gateway %></td>
                <td class="py-3 pr-4 text-white"><%= t.currency === 'INR' ? '₹' : '$' %><%= Number(t.amount).toFixed(2) %></td>
                <td class="py-3 pr-5 text-right">
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                    <%= t.status === 'paid' ? 'bg-green-400/10 text-green-400' : t.status === 'failed' ? 'bg-red-400/10 text-red-400' : 'bg-zinc-400/10 text-zinc-400' %>">
                    <%= t.status %>
                  </span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

      <!-- Danger zone -->
      <div>
        <h2 class="text-sm font-semibold text-red-400/70 mb-3">Danger Zone</h2>
        <div class="rounded-2xl border border-red-400/10 bg-red-400/5 p-5 flex items-center justify-between gap-x-4">
          <div>
            <p class="text-sm font-medium text-white">Sign out of all sessions</p>
            <p class="text-xs text-zinc-500 mt-0.5">This will log you out of this browser session.</p>
          </div>
          <form action="/logout" method="POST">
            <button type="submit" class="shrink-0 rounded-full bg-red-400/10 px-4 py-2 text-xs font-medium text-red-400 ring-1 ring-inset ring-red-400/20 hover:bg-red-400/20 transition">
              Sign Out
            </button>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>
</body>
</html>
