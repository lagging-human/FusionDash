<!doctype html>
<html class="h-full bg-[#0f1012]">
<%- include('../components/header') %>
<body class="h-full" style="font-family:'Space Grotesk'">
<div>
  <%- include('../components/sidebar', { activePage:'create' }) %>
  <main class="lg:pl-64">

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-400"><%= error %></p>
    </div>
    <% } %>

    <div class="carousel" data-stage="1">

      <!-- ── Stage 1: Name ── -->
      <div id="stage1">
        <nav class="flex items-center justify-center bg-zinc-700/10 border-b border-white/5 p-4 gap-x-3">
          <p class="text-sm font-medium text-white">Server details</p>
          <div class="flex gap-x-2 ml-4">
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
          </div>
        </nav>
        <div class="p-8 max-w-xl">
          <h2 class="text-base font-semibold text-white">Name your server</h2>
          <p class="mt-1 text-xs text-zinc-400 mb-6">Give your server an identifier.</p>
          <label class="block text-sm text-zinc-400 mb-2">Server Name</label>
          <input id="serverName" type="text" maxlength="60" placeholder="My Minecraft Server"
            class="block w-full rounded-full border-none py-3 pl-6 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 placeholder:text-zinc-500 focus:ring-1 focus:ring-blue-400 transition sm:text-sm">
        </div>
      </div>

      <!-- ── Stage 2: Resources ── -->
      <div id="stage2" class="hidden opacity-0">
        <nav class="flex items-center justify-center bg-zinc-700/10 border-b border-white/5 p-4 gap-x-3">
          <p class="text-sm font-medium text-white">Allocate resources</p>
          <div class="flex gap-x-2 ml-4">
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
            <span class="h-2 w-2 rounded-full bg-zinc-700"></span>
          </div>
        </nav>
        <div class="p-8 max-w-2xl">
          <h2 class="text-base font-semibold text-white mb-1">Allocate resources</h2>
          <p class="text-xs text-zinc-400 mb-6">Choose how much of your pool to allocate. You have <a href="/store" class="text-blue-400 hover:underline">resources available from your pool</a>.</p>

          <!-- Pool available chips -->
          <div class="flex flex-wrap gap-2 mb-6">
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400">Available: <strong class="text-white"><%= free.memory %> MB RAM</strong></span>
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400"><strong class="text-white"><%= free.disk %> MB Disk</strong></span>
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400"><strong class="text-white"><%= free.cpu %>% CPU</strong></span>
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400"><strong class="text-white"><%= free.ports %> Ports</strong></span>
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400"><strong class="text-white"><%= free.databases %> DBs</strong></span>
            <span class="rounded-full bg-zinc-700/40 px-3 py-1 text-xs text-zinc-400"><strong class="text-white"><%= free.backups %> Backups</strong></span>
          </div>

          <div class="space-y-5">
            <!-- RAM slider -->
            <div>
              <div class="flex items-center justify-between mb-1">
                <label class="text-sm text-zinc-400">RAM (MB)</label>
                <span id="memoryDisplay" class="text-sm font-semibold text-white">1024 MB</span>
              </div>
              <input type="range" id="memorySlider" min="128" max="<%= free.memory %>" step="128" value="1024"
                class="w-full h-1.5 appearance-none bg-zinc-700/50 rounded-full cursor-pointer accent-blue-400"
                oninput="document.getElementById('memoryDisplay').textContent=this.value+' MB';document.getElementById('memoryInput').value=this.value">
              <input type="hidden" id="memoryInput" value="1024">
            </div>
            <!-- Disk slider -->
            <div>
              <div class="flex items-center justify-between mb-1">
                <label class="text-sm text-zinc-400">Disk (MB)</label>
                <span id="diskDisplay" class="text-sm font-semibold text-white">1024 MB</span>
              </div>
              <input type="range" id="diskSlider" min="128" max="<%= free.disk %>" step="128" value="1024"
                class="w-full h-1.5 appearance-none bg-zinc-700/50 rounded-full cursor-pointer accent-blue-400"
                oninput="document.getElementById('diskDisplay').textContent=this.value+' MB';document.getElementById('diskInput').value=this.value">
              <input type="hidden" id="diskInput" value="1024">
            </div>
            <!-- CPU slider -->
            <div>
              <div class="flex items-center justify-between mb-1">
                <label class="text-sm text-zinc-400">CPU (%)</label>
                <span id="cpuDisplay" class="text-sm font-semibold text-white">50%</span>
              </div>
              <input type="range" id="cpuSlider" min="10" max="<%= free.cpu %>" step="10" value="50"
                class="w-full h-1.5 appearance-none bg-zinc-700/50 rounded-full cursor-pointer accent-blue-400"
                oninput="document.getElementById('cpuDisplay').textContent=this.value+'%';document.getElementById('cpuInput').value=this.value">
              <input type="hidden" id="cpuInput" value="50">
            </div>
            <!-- Ports / DBs / Backups -->
            <div class="grid grid-cols-3 gap-4">
              <div>
                <label class="text-xs text-zinc-400 block mb-1">Ports (max <%= free.ports %>)</label>
                <input id="portsInput" type="number" min="1" max="<%= free.ports %>" value="1"
                  class="w-full rounded-full border-none py-2 pl-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 text-sm focus:ring-blue-400">
              </div>
              <div>
                <label class="text-xs text-zinc-400 block mb-1">Databases (max <%= free.databases %>)</label>
                <input id="dbInput" type="number" min="0" max="<%= free.databases %>" value="0"
                  class="w-full rounded-full border-none py-2 pl-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 text-sm focus:ring-blue-400">
              </div>
              <div>
                <label class="text-xs text-zinc-400 block mb-1">Backups (max <%= free.backups %>)</label>
                <input id="backupInput" type="number" min="0" max="<%= free.backups %>" value="0"
                  class="w-full rounded-full border-none py-2 pl-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 text-sm focus:ring-blue-400">
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Stage 3: Software + Node ── -->
      <div id="stage3" class="hidden opacity-0">
        <nav class="flex items-center justify-center bg-zinc-700/10 border-b border-white/5 p-4 gap-x-3">
          <p class="text-sm font-medium text-white">Choose software & node</p>
          <div class="flex gap-x-2 ml-4">
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
            <span class="h-2 w-2 rounded-full bg-blue-400"></span>
          </div>
        </nav>
        <div class="p-8 max-w-xl">
          <h2 class="text-base font-semibold text-white mb-1">Software & Node</h2>
          <p class="text-xs text-zinc-400 mb-6">Pick the game/software and which node to deploy on.</p>
          <div class="space-y-5">
            <div>
              <label class="block text-sm text-zinc-400 mb-2">Software (Egg)</label>
              <select id="eggSelect"
                class="block w-full rounded-full border-none py-3 pl-6 pr-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 focus:ring-blue-400 sm:text-sm">
                <option value="" data-nest="">Select software…</option>
                <% nests.forEach(nest => { %>
                  <optgroup label="<%= nest.name %>">
                    <% nest.eggs.forEach(egg => { %>
                      <option value="<%= egg.id %>" data-nest="<%= nest.id %>"><%= egg.name %></option>
                    <% }) %>
                  </optgroup>
                <% }) %>
              </select>
              <input type="hidden" id="nestIdField">
              <input type="hidden" id="eggIdField">
            </div>
            <div>
              <label class="block text-sm text-zinc-400 mb-2">Node</label>
              <select id="nodeSelect"
                class="block w-full rounded-full border-none py-3 pl-6 pr-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 focus:ring-blue-400 sm:text-sm">
                <option value="">Select node…</option>
                <% nodes.forEach(node => { %>
                  <option value="<%= node.id %>" <%= node.maintenance_mode ? 'disabled' : '' %>>
                    <%= node.name %><%= node.maintenance_mode ? ' (maintenance)' : '' %>
                  </option>
                <% }) %>
              </select>
              <input type="hidden" id="nodeIdField">
            </div>

            <!-- Review summary -->
            <div id="reviewBox" class="hidden rounded-2xl bg-zinc-600/10 border border-white/5 p-4">
              <p class="text-xs font-semibold text-zinc-400 mb-3 uppercase tracking-wide">Review</p>
              <dl class="space-y-1.5">
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">Name</dt><dd class="text-white font-medium" id="rName">—</dd></div>
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">RAM</dt><dd class="text-white font-medium" id="rRam">—</dd></div>
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">Disk</dt><dd class="text-white font-medium" id="rDisk">—</dd></div>
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">CPU</dt><dd class="text-white font-medium" id="rCpu">—</dd></div>
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">Software</dt><dd class="text-white font-medium" id="rEgg">—</dd></div>
                <div class="flex justify-between text-sm"><dt class="text-zinc-400">Node</dt><dd class="text-white font-medium" id="rNode">—</dd></div>
              </dl>
            </div>
          </div>
        </div>
      </div>

      <!-- Nav buttons -->
      <div class="p-8 border-t border-white/5 flex items-center gap-x-3">
        <button id="backBtn" onclick="navBack()" class="hidden rounded-full bg-zinc-600/20 px-6 py-2 text-sm font-medium text-zinc-300 ring-1 ring-inset ring-zinc-600/30 hover:bg-zinc-600/30 transition">Back</button>
        <button id="nextBtn" onclick="navNext()" class="rounded-full bg-blue-400/10 px-6 py-2 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">Continue</button>
      </div>

    </div><!-- /.carousel -->
  </main>
</div>

<script>
  const carousel = document.querySelector('.carousel');

  function goTo(to) {
    const from = parseInt(carousel.dataset.stage);
    const fromEl = document.getElementById(`stage${from}`);
    const toEl   = document.getElementById(`stage${to}`);
    fromEl.classList.add('opacity-0');
    setTimeout(() => {
      fromEl.classList.add('hidden');
      toEl.classList.remove('hidden');
      setTimeout(() => toEl.classList.remove('opacity-0'), 20);
      carousel.dataset.stage = to;
      document.getElementById('backBtn').classList.toggle('hidden', to === 1);
      document.getElementById('nextBtn').textContent = to === 3 ? 'Create Server' : 'Continue';
      // Show review on stage 3
      if (to === 3) updateReview();
    }, 200);
  }

  function updateReview() {
    document.getElementById('rName').textContent  = document.getElementById('serverName').value || '—';
    document.getElementById('rRam').textContent   = document.getElementById('memoryInput').value + ' MB';
    document.getElementById('rDisk').textContent  = document.getElementById('diskInput').value + ' MB';
    document.getElementById('rCpu').textContent   = document.getElementById('cpuInput').value + '%';
    const eggOpt  = document.getElementById('eggSelect');
    const nodeOpt = document.getElementById('nodeSelect');
    document.getElementById('rEgg').textContent  = eggOpt.options[eggOpt.selectedIndex]?.text || '—';
    document.getElementById('rNode').textContent = nodeOpt.options[nodeOpt.selectedIndex]?.text || '—';
    document.getElementById('reviewBox').classList.remove('hidden');
  }

  function navNext() {
    const stage = parseInt(carousel.dataset.stage);
    if (stage === 1) {
      if (!document.getElementById('serverName').value.trim()) { alert('Enter a server name.'); return; }
      goTo(2);
    } else if (stage === 2) {
      if (parseInt(document.getElementById('memoryInput').value) <= 0) { alert('Select RAM.'); return; }
      goTo(3);
    } else if (stage === 3) {
      const egg  = document.getElementById('eggIdField').value;
      const node = document.getElementById('nodeIdField').value;
      if (!egg || !node) { alert('Select software and a node.'); return; }
      submitForm();
    }
  }

  function navBack() {
    const stage = parseInt(carousel.dataset.stage);
    if (stage > 1) goTo(stage - 1);
  }

  function submitForm() {
    const form = document.createElement('form');
    form.method = 'POST'; form.action = '/servers/create';
    const data = {
      name:      document.getElementById('serverName').value.trim(),
      memory:    document.getElementById('memoryInput').value,
      disk:      document.getElementById('diskInput').value,
      cpu:       document.getElementById('cpuInput').value,
      ports:     document.getElementById('portsInput').value,
      databases: document.getElementById('dbInput').value,
      backups:   document.getElementById('backupInput').value,
      nest_id:   document.getElementById('nestIdField').value,
      egg_id:    document.getElementById('eggIdField').value,
      node_id:   document.getElementById('nodeIdField').value,
    };
    for (const [k,v] of Object.entries(data)) {
      const i = document.createElement('input');
      i.type='hidden'; i.name=k; i.value=v;
      form.appendChild(i);
    }
    document.body.appendChild(form);
    form.submit();
  }

  // Sync egg → nest
  document.getElementById('eggSelect').addEventListener('change', function() {
    const opt = this.options[this.selectedIndex];
    document.getElementById('nestIdField').value = opt.dataset.nest || '';
    document.getElementById('eggIdField').value  = opt.value || '';
  });
  document.getElementById('nodeSelect').addEventListener('change', function() {
    document.getElementById('nodeIdField').value = this.value;
  });
</script>
</body>
</html>
