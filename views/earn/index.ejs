<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'earn' }) %>

<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-sm font-semibold text-white">Earn Coins</p>
      <p class="text-xs text-zinc-500 mt-0.5">Complete tasks to earn coins and expand your resource pool.</p>
    </div>
    <div class="flex items-center gap-x-2 rounded-full bg-yellow-400/10 px-4 py-2 ring-1 ring-inset ring-yellow-400/20">
      <%- icon('coin', 'h-4 w-4 text-yellow-400') %>
      <span class="text-sm font-bold text-yellow-400"><%= user.coins %> coins</span>
    </div>
  </div>

  <div class="px-4 sm:px-6 lg:px-8 py-6 pb-16 max-w-4xl space-y-4">

    <!-- Daily Bonus -->
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-hidden">
      <div class="flex items-center gap-x-3 px-5 py-3 border-b border-white/[0.06] bg-white/[0.02]">
        <%- icon('calendar', 'h-5 w-5 text-zinc-300') %>
        <p class="text-sm font-semibold text-white">Daily Bonus</p>
        <span class="ml-auto inline-flex items-center rounded-full bg-green-500/10 px-2.5 py-0.5 text-xs font-medium text-green-400 ring-1 ring-inset ring-green-500/20">FREE</span>
      </div>
      <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs text-zinc-400">Claim <span class="inline-flex items-center gap-x-1 text-yellow-400 font-semibold"><%- icon('coin', 'h-3.5 w-3.5') %> <%= dailyCoins %> coins</span> once every 24 hours.</p>
          <% if (!canClaimDaily) { %>
          <p class="text-xs text-zinc-600 mt-1" id="countdown" data-seconds="<%= dailyNextIn %>">
            Next claim in <%= Math.floor(dailyNextIn/3600) %>h <%= Math.floor((dailyNextIn%3600)/60) %>m
          </p>
          <% } %>
        </div>
        <% if (canClaimDaily) { %>
        <form action="/earn/daily" method="POST">
          <button type="submit" class="rounded-full bg-yellow-400/15 px-5 py-2 text-sm font-semibold text-yellow-400 ring-1 ring-inset ring-yellow-400/30 hover:bg-yellow-400/25 transition-colors">
            Claim Now
          </button>
        </form>
        <% } else { %>
        <div class="rounded-full bg-zinc-800/60 px-5 py-2 text-sm font-medium text-zinc-600 ring-1 ring-inset ring-white/[0.06] cursor-not-allowed">
          Already Claimed
        </div>
        <% } %>
      </div>
    </div>

    <!-- Work.ink -->
    <% if (apis.workink) { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-hidden">
      <div class="flex items-center gap-x-3 px-5 py-3 border-b border-white/[0.06] bg-white/[0.02]">
        <%- icon('link', 'h-5 w-5 text-zinc-300') %>
        <p class="text-sm font-semibold text-white">Work.ink</p>
        <span class="ml-2 text-xs text-zinc-500">Complete surveys, installs & videos</span>
        <span class="ml-auto inline-flex items-center rounded-full bg-blue-500/10 px-2.5 py-0.5 text-xs font-medium text-blue-400 ring-1 ring-inset ring-blue-500/20"><span class="inline-flex items-center gap-x-1"><%- icon('coin', 'h-3.5 w-3.5') %> <%= workinkCoins %> / offer</span></span>
      </div>
      <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-4">
        <p class="text-xs text-zinc-400 max-w-sm">Complete offers on Work.ink — surveys, app installs, videos. Coins are awarded automatically after completion.</p>
        <a href="/earn/workink" target="_blank"
          class="rounded-full bg-blue-500/15 px-5 py-2 text-sm font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
          Go to Offers →
        </a>
      </div>
    </div>
    <% } %>

    <!-- Paymentwall -->
    <% if (apis.paymentwall) { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-hidden">
      <div class="flex items-center gap-x-3 px-5 py-3 border-b border-white/[0.06] bg-white/[0.02]">
        <%- icon('card', 'h-5 w-5 text-zinc-300') %>
        <p class="text-sm font-semibold text-white">Paymentwall Offerwall</p>
        <span class="ml-2 text-xs text-zinc-500">Surveys, subscriptions & more</span>
        <span class="ml-auto inline-flex items-center rounded-full bg-purple-500/10 px-2.5 py-0.5 text-xs font-medium text-purple-400 ring-1 ring-inset ring-purple-500/20">Variable rewards</span>
      </div>
      <div class="px-5 py-4">
        <p class="text-xs text-zinc-400 mb-3">Complete offers from the Paymentwall network. Coins are awarded per pingback.</p>
        <!-- Embedded Paymentwall widget iframe -->
        <div class="rounded-xl overflow-hidden border border-white/[0.06]" style="height:500px">
          <iframe
            src="https://api.paymentwall.com/api/subscription/?key=<%= apis.paymentwall.appKey %>&uid=<%= encodeURIComponent(user.id) %>&widget=<%= apis.paymentwall.widget || 'mw6' %>&email=<%= encodeURIComponent(user.email || '') %>&timestamp=<%= Date.now() %>"
            style="width:100%;height:100%;border:0"
            scrolling="yes"
            allowtransparency="true">
          </iframe>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Notik -->
    <% if (apis.notik) { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-hidden">
      <div class="flex items-center gap-x-3 px-5 py-3 border-b border-white/[0.06] bg-white/[0.02]">
        <%- icon('bolt', 'h-5 w-5 text-zinc-300') %>
        <p class="text-sm font-semibold text-white">Notik Offerwall</p>
        <span class="ml-2 text-xs text-zinc-500">App installs, CPI & missions</span>
        <span class="ml-auto inline-flex items-center rounded-full bg-orange-500/10 px-2.5 py-0.5 text-xs font-medium text-orange-400 ring-1 ring-inset ring-orange-500/20"><span class="inline-flex items-center gap-x-1"><%- icon('coin', 'h-3.5 w-3.5') %> <%= notikCoins %> / offer</span></span>
      </div>
      <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-4">
        <p class="text-xs text-zinc-400 max-w-sm">Complete app installs, missions, and tasks via Notik. Coins credited automatically via postback.</p>
        <a href="/earn/notik" target="_blank"
          class="rounded-full bg-orange-500/15 px-5 py-2 text-sm font-semibold text-orange-400 ring-1 ring-inset ring-orange-500/30 hover:bg-orange-500/25 transition-colors">
          Go to Offers →
        </a>
      </div>
    </div>
    <% } %>

    <!-- Linkvertise -->
    <% if (apis.linkvertise) { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] overflow-hidden">
      <div class="flex items-center gap-x-3 px-5 py-3 border-b border-white/[0.06] bg-white/[0.02]">
        <%- icon('link', 'h-5 w-5 text-zinc-300') %>
        <p class="text-sm font-semibold text-white">Linkvertise</p>
        <span class="ml-2 text-xs text-zinc-500">Quick link unlock</span>
        <span class="ml-auto inline-flex items-center rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-medium text-emerald-400 ring-1 ring-inset ring-emerald-500/20"><span class="inline-flex items-center gap-x-1"><%- icon('coin', 'h-3.5 w-3.5') %> <%= linkvertiseCoins %> / offer</span></span>
      </div>
      <div class="px-5 py-4 flex flex-wrap items-center justify-between gap-4">
        <p class="text-xs text-zinc-400 max-w-sm">Complete the Linkvertise unlock steps. Coins are awarded automatically after completion.</p>
        <a href="/earn/linkvertise" target="_blank"
          class="rounded-full bg-emerald-500/15 px-5 py-2 text-sm font-semibold text-emerald-400 ring-1 ring-inset ring-emerald-500/30 hover:bg-emerald-500/25 transition-colors">
          Go to Link →
        </a>
      </div>
    </div>
    <% } %>

    <!-- If no earn APIs configured yet -->
    <% if (!apis.workink && !apis.paymentwall && !apis.notik && !apis.linkvertise) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-10 text-center">
      <p class="text-sm text-zinc-500">No earn APIs configured yet.</p>
      <p class="text-xs text-zinc-600 mt-1">An admin can enable Work.ink, Paymentwall, Notik, and Linkvertise from the Admin Panel.</p>
    </div>
    <% } %>

    <!-- Recent coin activity -->
    <div class="pt-4">
      <p class="text-sm font-semibold text-white mb-3">Recent Activity</p>
      <% if (recentLog.length === 0) { %>
      <div class="rounded-2xl border border-dashed border-white/10 py-8 text-center">
        <p class="text-sm text-zinc-500">No coin activity yet.</p>
      </div>
      <% } else { %>
      <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
        <table class="w-full text-left text-sm">
          <thead class="bg-white/[0.02] border-b border-white/[0.06]">
            <tr>
              <th class="py-2.5 pl-4 pr-6 text-xs font-semibold text-zinc-500">Source</th>
              <th class="py-2.5 pr-6 text-xs font-semibold text-zinc-500">Amount</th>
              <th class="py-2.5 pr-4 text-xs font-semibold text-zinc-500 text-right">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/[0.04]">
            <% recentLog.forEach(log => { %>
            <tr class="hover:bg-white/[0.015] transition-colors">
              <td class="py-3 pl-4 pr-6 text-zinc-300 capitalize text-xs"><%= (log.reason||'').replace(/_/g,' ') %></td>
              <td class="py-3 pr-6 font-semibold text-xs <%= log.delta > 0 ? 'text-green-400' : 'text-red-400' %>">
                <span class="inline-flex items-center gap-x-1"><%= log.delta > 0 ? '+' : '' %><%= log.delta %> <%- icon('coin', 'h-3.5 w-3.5') %></span>
              </td>
              <td class="py-3 pr-4 text-zinc-600 text-xs text-right"><%= new Date(log.created_at).toLocaleDateString('en-IN') %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </div>
</div>

<script>
  const el = document.getElementById('countdown');
  if (el) {
    let s = parseInt(el.dataset.seconds, 10) || 0;
    const fmt = s => `${Math.floor(s/3600)}h ${Math.floor((s%3600)/60)}m ${s%60}s`;
    el.textContent = `Next claim in ${fmt(s)}`;
    const iv = setInterval(() => {
      s = Math.max(0, s-1);
      el.textContent = `Next claim in ${fmt(s)}`;
      if (s === 0) { clearInterval(iv); location.reload(); }
    }, 1000);
  }
</script>
</body>
</html>
