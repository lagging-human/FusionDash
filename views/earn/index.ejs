<!doctype html>
<html class="h-full bg-[#0f1012]">
<%- include('../components/header') %>
<body class="h-full" style="font-family:'Space Grotesk'">
<div>
  <%- include('../components/sidebar', { activePage:'earn' }) %>
  <main class="lg:pl-64">

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-400"><%= error %></p>
    </div>
    <% } %>
    <% if (success) { %>
    <div class="border border-green-400/10 bg-green-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      <p class="text-sm text-green-400"><%= success %></p>
    </div>
    <% } %>

    <div class="flex items-center justify-between bg-zinc-700/10 border-b border-white/5 px-4 py-4 sm:px-6 lg:px-8">
      <div>
        <h1 class="text-base font-semibold text-white">Earn Coins</h1>
        <p class="mt-1 text-xs text-zinc-400">Complete tasks to earn coins and buy resources.</p>
      </div>
      <div class="flex items-center gap-x-2 rounded-full bg-yellow-400/10 px-4 py-2 ring-1 ring-inset ring-yellow-400/20">
        <span class="text-base">🪙</span>
        <span class="text-sm font-semibold text-yellow-400"><%= user.coins %> coins</span>
      </div>
    </div>

    <div class="px-4 sm:px-6 lg:px-8 py-8 max-w-3xl space-y-6">

      <!-- Daily claim -->
      <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6">
        <div class="flex items-start justify-between gap-x-4">
          <div>
            <div class="flex items-center gap-x-2">
              <span class="text-2xl">📅</span>
              <h2 class="text-sm font-semibold text-white">Daily Bonus</h2>
            </div>
            <p class="mt-1.5 text-xs text-zinc-400">Claim <strong class="text-yellow-400"><%= dailyCoins %> coins</strong> every 24 hours for free.</p>
          </div>
          <% if (canClaimDaily) { %>
          <form action="/earn/daily" method="POST" class="shrink-0">
            <button type="submit" class="rounded-full bg-yellow-400/10 px-5 py-2 text-sm font-medium text-yellow-400 ring-1 ring-inset ring-yellow-400/20 hover:bg-yellow-400/20 transition">
              Claim
            </button>
          </form>
          <% } else { %>
          <div class="shrink-0 text-right">
            <div class="rounded-full bg-zinc-700/30 px-5 py-2 text-sm font-medium text-zinc-600 ring-1 ring-inset ring-zinc-600/20 cursor-not-allowed inline-block">
              Claimed
            </div>
            <p class="text-xs text-zinc-600 mt-1" id="countdown" data-seconds="<%= dailyNextIn %>">
              Next in <%= Math.floor(dailyNextIn/3600) %>h <%= Math.floor((dailyNextIn%3600)/60) %>m
            </p>
          </div>
          <% } %>
        </div>
      </div>

      <!-- Work.ink -->
      <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6">
        <div class="flex items-start justify-between gap-x-4">
          <div class="flex-1">
            <div class="flex items-center gap-x-2">
              <span class="text-2xl">🔗</span>
              <h2 class="text-sm font-semibold text-white">Work.ink Offers</h2>
            </div>
            <p class="mt-1.5 text-xs text-zinc-400">
              Complete tasks like surveys, installs, or short videos on Work.ink.
              Earn <strong class="text-yellow-400"><%= workinkCoins %> coins</strong> per completed offer.
            </p>
            <p class="mt-2 text-xs text-zinc-600">Coins are awarded automatically after offer completion.</p>
          </div>
          <div class="shrink-0">
            <% if (workinkOfferId) { %>
            <a href="/earn/workink" target="_blank"
              class="inline-block rounded-full bg-blue-400/10 px-5 py-2 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">
              Go to Offers →
            </a>
            <% } else { %>
            <span class="inline-block rounded-full bg-zinc-700/30 px-5 py-2 text-sm font-medium text-zinc-600 ring-1 ring-inset ring-zinc-600/20">
              Coming Soon
            </span>
            <% } %>
          </div>
        </div>
      </div>

      <!-- More ways card placeholder (admin can add in future) -->
      <div class="rounded-2xl border border-dashed border-white/10 p-6 text-center">
        <p class="text-sm text-zinc-600">More ways to earn coins coming soon.</p>
      </div>

      <!-- Recent coin history -->
      <div>
        <h2 class="text-sm font-semibold text-zinc-300 mb-3">Recent Activity</h2>
        <% if (recentLog.length === 0) { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-6 text-center">
          <p class="text-sm text-zinc-500">No coin activity yet.</p>
        </div>
        <% } else { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 overflow-hidden">
          <table class="w-full text-left text-sm">
            <thead class="border-b border-white/5 text-xs text-zinc-500">
              <tr>
                <th class="py-3 pl-5 pr-4 font-medium">Reason</th>
                <th class="py-3 pr-4 font-medium">Amount</th>
                <th class="py-3 pr-5 font-medium text-right">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
              <% recentLog.forEach(log => { %>
              <tr>
                <td class="py-3 pl-5 pr-4 text-zinc-300 capitalize"><%= log.reason?.replace(/_/g,' ') || '—' %></td>
                <td class="py-3 pr-4 font-semibold <%= log.delta > 0 ? 'text-green-400' : 'text-red-400' %>">
                  <%= log.delta > 0 ? '+' : '' %><%= log.delta %> 🪙
                </td>
                <td class="py-3 pr-5 text-zinc-500 text-xs text-right"><%= new Date(log.created_at).toLocaleDateString('en-IN') %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>
      </div>

    </div>
  </main>
</div>

<script>
  // Live countdown timer
  const el = document.getElementById('countdown');
  if (el) {
    let secs = parseInt(el.dataset.seconds, 10) || 0;
    function fmt(s) {
      const h = Math.floor(s/3600), m = Math.floor((s%3600)/60), sec = s%60;
      return `${h}h ${m}m ${sec}s`;
    }
    el.textContent = `Next in ${fmt(secs)}`;
    const iv = setInterval(() => {
      secs = Math.max(0, secs - 1);
      el.textContent = `Next in ${fmt(secs)}`;
      if (secs === 0) { clearInterval(iv); location.reload(); }
    }, 1000);
  }
</script>
</body>
</html>
