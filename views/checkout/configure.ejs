<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>

  <%- include('../components/sidebar', { activePage: 'dashboard' }) %>
  <div class="app-main">

    <div class="flex items-center justify-between bg-zinc-700/10 border-b border-white/5 px-4 py-4 sm:px-6 lg:px-8">
      <div>
        <h1 class="text-base font-semibold text-white">Checkout â€” <%= plan.name %></h1>
        <p class="mt-1 text-xs text-zinc-400">Configure your new server before paying.</p>
      </div>
      <a href="/dashboard" class="text-xs text-zinc-500 hover:text-zinc-300 transition">&larr; Back</a>
    </div>

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4">
      <p class="ml-3 text-sm text-amber-400"><%= error %></p>
    </div>
    <% } %>

    <div class="p-8 max-w-2xl">

      <!-- Plan summary -->
      <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-5 mb-8">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold text-white"><%= plan.name %> Plan</p>
          <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium bg-blue-400/10 text-blue-400 ring-1 ring-inset ring-blue-400/20">
            <%= gateway === 'paypal' ? '$' + plan.price_usd.toFixed(2) + ' USD' : 'â‚¹' + (plan.price_inr/100).toFixed(2) + ' INR' %>
          </span>
        </div>
        <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-400">
          <span><%= (plan.memory/1024).toFixed(1) %> GiB RAM</span>
          <span class="text-zinc-600">/</span>
          <span><%= (plan.disk/1024).toFixed(0) %> GiB Disk</span>
          <span class="text-zinc-600">/</span>
          <span><%= (plan.cpu/100).toFixed(1) %> CPU cores</span>
          <span class="text-zinc-600">/</span>
          <span><%= plan.databases %> databases</span>
          <span class="text-zinc-600">/</span>
          <span><%= plan.backups %> backups</span>
          <span class="text-zinc-600">/</span>
          <span><%= plan.ports || 1 %> port<%= (plan.ports||1) !== 1 ? 's' : '' %></span>
        </div>
        <p class="mt-3 text-xs text-zinc-500">
          Paying via <strong class="text-zinc-300"><%= gateway === 'paypal' ? 'PayPal' : 'UPI / Razorpay' %></strong>.
          <a href="/dashboard#plans" class="text-blue-400 hover:underline ml-2">Switch gateway</a>
        </p>
      </div>

      <!-- Server config form -->
      <form action="/checkout/<%= plan.key %>/pay" method="POST" class="space-y-6">
        <input type="hidden" name="gateway" value="<%= gateway %>">

        <div>
          <label class="block text-sm font-normal leading-6 text-zinc-400 mb-2">Server name</label>
          <input type="text" name="name" placeholder="My <%= plan.name %> Server" maxlength="60"
            class="block w-full rounded-full border-none py-3 pl-6 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 placeholder:text-zinc-500 focus:ring-1 focus:ring-blue-400 transition sm:text-sm">
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-normal leading-6 text-zinc-400 mb-2">Software</label>
            <select name="egg_id" id="eggSelect" required
              class="block w-full rounded-full border-none py-3 pl-6 pr-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 focus:ring-blue-400 transition sm:text-sm">
              <option value="" data-nest="">Select softwareâ€¦</option>
              <% nests.forEach(nest => { %>
                <optgroup label="<%= nest.name %>">
                  <% nest.eggs.forEach(egg => { %>
                    <option value="<%= egg.id %>" data-nest="<%= nest.id %>"><%= egg.name %></option>
                  <% }) %>
                </optgroup>
              <% }) %>
            </select>
            <input type="hidden" name="nest_id" id="nestIdField">
          </div>
          <div>
            <label class="block text-sm font-normal leading-6 text-zinc-400 mb-2">Node</label>
            <select name="node_id" required
              class="block w-full rounded-full border-none py-3 pl-6 pr-4 bg-zinc-600/20 text-white ring-1 ring-inset ring-zinc-600/30 focus:ring-blue-400 transition sm:text-sm">
              <option value="">Select nodeâ€¦</option>
              <% nodes.forEach(node => { %>
                <option value="<%= node.id %>" <%= node.maintenance_mode ? 'disabled' : '' %>>
                  <%= node.name %><%= node.maintenance_mode ? ' (maintenance)' : '' %>
                </option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="pt-2">
          <button type="submit" class="rounded-full bg-blue-400/10 px-8 py-2.5 text-sm font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">
            Continue to Payment &rarr;
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const eggSelect = document.getElementById('eggSelect');
  eggSelect.addEventListener('change', function() {
    document.getElementById('nestIdField').value = this.options[this.selectedIndex].dataset.nest || '';
  });
</script>
</body>
</html>
