<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Server Plans</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-zinc-200 min-h-screen">

<!-- Topbar -->
<div class="flex items-center justify-between px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
  <a href="/" class="text-sm font-semibold text-white">Dashboard</a>
  <div class="flex items-center gap-x-2">
    <a href="/" class="rounded-lg border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-zinc-300 hover:border-white/20 hover:text-white transition-colors">Home</a>
    <% if (typeof user === 'undefined' || !user) { %>
    <a href="/login" class="rounded-lg border border-blue-500/30 bg-blue-500/15 px-3 py-1.5 text-xs font-semibold text-blue-400 hover:bg-blue-500/25 transition-colors">Login</a>
    <% } %>
  </div>
</div>

<div class="px-4 pt-10 pb-16 sm:px-6 lg:px-8 max-w-6xl mx-auto">

  <!-- Header -->
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold text-white mb-2">Dedicated Server Plans</h1>
    <p class="text-sm text-zinc-500">Reliable hosting with guaranteed resources, billed monthly.</p>
    <% if (plans.length > 0) { %>
    <p class="text-xs text-zinc-600 mt-3"><%= plans.length %> plan<%= plans.length !== 1 ? 's' : '' %> available</p>
    <% } %>
  </div>

  <!-- Plans -->
  <% if (plans.length === 0) { %>
  <div class="rounded-2xl border border-dashed border-white/10 py-14 text-center">
    <p class="text-sm text-zinc-500">No plans available yet</p>
    <p class="text-xs text-zinc-600 mt-1">Check back later or contact the admin.</p>
  </div>
  <% } else { %>
  <div class="card-grid grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    <% plans.forEach(plan => { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6 hover:border-blue-500/30 transition-colors flex flex-col">
      <p class="text-lg font-semibold text-white mb-4"><%= plan.name %></p>
      <ul class="space-y-2 text-xs text-zinc-400 mb-6 flex-1">
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.memory/1024).toFixed(1) %> GiB RAM</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.disk/1024).toFixed(0) %> GiB Disk</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.cpu/100).toFixed(1) %> CPU cores</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= plan.databases %> Database<%= plan.databases !== 1 ? 's' : '' %> / <%= plan.backups %> Backup<%= plan.backups !== 1 ? 's' : '' %></li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= plan.ports || 1 %> Port<%= (plan.ports||1) !== 1 ? 's' : '' %></li>
      </ul>
      <div class="border-t border-white/[0.06] pt-4">
        <p class="text-2xl font-bold text-white">₹<%= (plan.price_inr/100).toFixed(0) %><span class="text-xs font-normal text-zinc-500">/mo</span></p>
        <p class="text-xs text-zinc-600 mb-4">or $<%= plan.price_usd.toFixed(2) %>/mo</p>
        <a href="/checkout/<%= plan.key %>" class="block text-center rounded-full bg-blue-500/15 px-3 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Get Started</a>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>

  <!-- Info -->
  <div class="text-center mt-14">
    <p class="text-sm text-zinc-500">All plans include 24/7 support and automatic updates</p>
    <p class="text-xs text-zinc-600 mt-1">Questions? Contact our support team</p>
  </div>

</div>
</body>
</html>
