<%
  // Expects: plans (array), gateways ({ razorpay, paypal })
  const gw = typeof gateways !== 'undefined' ? gateways : { razorpay: true, paypal: true };
%>
<div id="plans" class="px-4 pt-2 pb-16 sm:px-6 lg:px-8">
  <div class="mb-5 flex items-end justify-between">
    <div>
      <p class="text-sm font-semibold text-white">Available Plans</p>
      <p class="text-xs text-zinc-500 mt-0.5">Dedicated server with guaranteed resources, billed monthly.</p>
    </div>
    <% if (plans.length > 0) { %>
    <span class="text-[10px] text-zinc-600"><%= plans.length %> plan<%= plans.length !== 1 ? 's' : '' %></span>
    <% } %>
  </div>

  <% if (plans.length === 0) { %>
  <div class="rounded-2xl border border-dashed border-white/10 py-10 text-center">
    <p class="text-sm text-zinc-500">No plans available yet.</p>
    <p class="text-xs text-zinc-600 mt-1">Check back later or contact the admin.</p>
  </div>
  <% } else if (!gw.razorpay && !gw.paypal) { %>
  <div class="rounded-2xl border border-dashed border-white/10 py-10 text-center">
    <p class="text-sm text-zinc-500">No payment methods configured yet.</p>
    <p class="text-xs text-zinc-600 mt-1">Ask the admin to set up Razorpay or PayPal in .env.</p>
  </div>
  <% } else { %>
  <div class="card-grid">
    <% plans.forEach(plan => { %>
    <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-5 hover:border-blue-500/20 transition-colors flex flex-col">
      <p class="text-sm font-semibold text-white mb-3"><%= plan.name %></p>
      <ul class="space-y-1.5 text-xs text-zinc-400 mb-5 flex-1">
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.memory/1024).toFixed(1) %> GiB RAM</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.disk/1024).toFixed(0) %> GiB Disk</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= (plan.cpu/100).toFixed(1) %> CPU cores</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= plan.databases %> Databases / <%= plan.backups %> Backups</li>
        <li class="flex items-center gap-x-2"><span class="h-1 w-1 rounded-full bg-blue-400 shrink-0"></span><%= plan.ports || 1 %> Port<%= (plan.ports||1) !== 1 ? 's' : '' %></li>
      </ul>
      <div class="flex items-end justify-between">
        <div>
          <p class="text-xl font-bold text-white">₹<%= (plan.price_inr/100).toFixed(0) %><span class="text-xs font-normal text-zinc-500">/mo</span></p>
          <p class="text-xs text-zinc-600">or $<%= plan.price_usd.toFixed(2) %>/mo</p>
        </div>
        <div class="flex flex-col gap-y-1.5">
          <% if (gw.razorpay) { %>
          <a href="/checkout/<%= plan.key %>?gateway=razorpay" class="rounded-full bg-blue-500/15 px-3 py-1.5 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors text-center">UPI / Razorpay</a>
          <% } %>
          <% if (gw.paypal) { %>
          <a href="/checkout/<%= plan.key %>?gateway=paypal" class="rounded-full bg-white/[0.05] px-3 py-1.5 text-xs font-semibold text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-white/[0.08] transition-colors text-center">PayPal</a>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>
