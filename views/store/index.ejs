<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'store' }) %>

<div class="app-main">

  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <!-- Header -->
  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-sm font-semibold text-white">Resource Store</p>
      <p class="text-xs text-zinc-500 mt-0.5">Buy resources with coins. Choose quantity before purchasing.</p>
    </div>
    <div class="flex items-center gap-x-3">
      <div class="flex items-center gap-x-2 rounded-full bg-yellow-400/10 px-4 py-2 ring-1 ring-inset ring-yellow-400/20">
        <%- icon('coin', 'h-4 w-4 text-yellow-400') %>
        <span class="text-sm font-bold text-yellow-400"><%= user.coins %></span>
      </div>
      <a href="/earn" class="rounded-full bg-white/[0.05] px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-white/[0.08] transition-colors">+ Earn Coins</a>
    </div>
  </div>

  <!-- Current pool summary -->
  <div class="px-4 sm:px-6 lg:px-8 pt-5">
    <p class="text-xs font-semibold text-zinc-500 uppercase tracking-widest mb-3">Your Pool</p>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mb-6">
      <%
        const pool = [
          { label:'RAM',   val: (user.res_memory/1024).toFixed(1)+' GiB' },
          { label:'Disk',  val: (user.res_disk/1024).toFixed(1)+' GiB'   },
          { label:'CPU',   val: user.res_cpu+'%'                          },
          { label:'Ports', val: user.res_ports+''                         },
          { label:'DBs',   val: user.res_databases+''                     },
          { label:'Bkps',  val: user.res_backups+''                       },
        ];
      %>
      <% pool.forEach(p => { %>
      <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] px-3 py-2 text-center">
        <p class="text-[10px] text-zinc-600 uppercase tracking-wide"><%= p.label %></p>
        <p class="text-sm font-bold text-white mt-0.5"><%= p.val %></p>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Store items grouped by resource type -->
  <%
    const groups = {
      memory:    { label:'RAM',       iconName:'memory', color:'blue',   items:[] },
      disk:      { label:'Disk',      iconName:'disk', color:'purple', items:[] },
      cpu:       { label:'CPU',       iconName:'bolt', color:'yellow', items:[] },
      ports:     { label:'Ports',     iconName:'plug', color:'green',  items:[] },
      databases: { label:'Databases', iconName:'database', color:'orange', items:[] },
      backups:   { label:'Backups',   iconName:'box', color:'pink',   items:[] },
    };
    items.forEach(i => { if (groups[i.resource]) groups[i.resource].items.push(i); });
    const colorMap = { blue:'bg-blue-500/10 text-blue-400 ring-blue-500/20', purple:'bg-purple-500/10 text-purple-400 ring-purple-500/20', yellow:'bg-yellow-500/10 text-yellow-400 ring-yellow-500/20', green:'bg-green-500/10 text-green-400 ring-green-500/20', orange:'bg-orange-500/10 text-orange-400 ring-orange-500/20', pink:'bg-pink-500/10 text-pink-400 ring-pink-500/20' };
  %>

  <div class="px-4 sm:px-6 lg:px-8 pb-16 space-y-6">
    <% Object.values(groups).filter(g => g.items.length).forEach(group => { %>
    <div>
      <div class="flex items-center gap-x-2 mb-3">
        <%- icon(group.iconName, 'h-4 w-4') %>
        <p class="text-sm font-semibold text-white"><%= group.label %></p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <% group.items.forEach(item => { %>
        <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-4 hover:border-white/10 transition-colors">
          <div class="flex items-start justify-between gap-x-3 mb-3">
            <div class="min-w-0">
              <p class="text-sm font-semibold text-white"><%= item.name %></p>
              <p class="text-xs text-zinc-500 mt-0.5"><%= item.description %></p>
            </div>
            <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ring-1 ring-inset <%= colorMap[group.color] %>">
              <%- icon('coin', 'h-3.5 w-3.5') %> <%= item.cost %>
            </span>
          </div>

          <!-- Quantity selector + buy -->
          <form action="/store/buy/<%= item.key %>" method="POST" class="flex items-center gap-x-2">
            <!-- Quick qty buttons -->
            <div class="flex items-center gap-x-1">
              <% [1,2,5,10].forEach(n => { %>
              <button type="submit" name="qty" value="<%= n %>"
                <% if (user.coins < item.cost * n) { %> disabled <% } %>
                class="rounded-lg px-2.5 py-1.5 text-xs font-semibold transition-colors
                  <%= user.coins >= item.cost * n
                    ? 'bg-blue-500/15 text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25'
                    : 'bg-zinc-800/60 text-zinc-600 ring-1 ring-inset ring-white/[0.04] cursor-not-allowed' %>">
                <%= n %>x
              </button>
              <% }) %>
            </div>
            <!-- Custom qty -->
            <div class="flex items-center gap-x-1 ml-auto">
              <input type="number" name="qty" min="1" max="100" value="1" placeholder="Qty"
                class="w-14 rounded-lg border-none py-1.5 pl-2 bg-zinc-800/60 text-white ring-1 ring-inset ring-white/[0.08] text-xs focus:ring-blue-400 text-center"
                onchange="updateCost(this, <%= item.cost %>)">
              <button type="submit"
                class="rounded-lg bg-zinc-700/60 px-2.5 py-1.5 text-xs font-semibold text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-700 transition-colors">
                Buy
              </button>
            </div>
          </form>
          <p class="text-[10px] text-zinc-600 mt-2">
            Cost per unit: <%- icon('coin', 'h-3.5 w-3.5') %> <%= item.cost %> &nbsp;·&nbsp; Your balance: <%- icon('coin', 'h-3 w-3 inline-block align-middle') %> <%= user.coins %>
          </p>
        </div>
        <% }) %>
      </div>
    </div>
    <% }) %>

    <% if (!items.length) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-14 text-center">
      <p class="text-sm text-zinc-500">No store items available.</p>
    </div>
    <% } %>
  </div>
</div>

<script>
  function updateCost(input, costPerUnit) {
    const qty = parseInt(input.value) || 1;
    // Could show a total cost preview here in future
  }
</script>
</body>
</html>
