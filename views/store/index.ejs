<!doctype html>
<html class="h-full bg-[#0f1012]">
<%- include('../components/header') %>
<body class="h-full" style="font-family:'Space Grotesk'">
<div>
  <%- include('../components/sidebar', { activePage:'store' }) %>
  <main class="lg:pl-64">

    <% if (error) { %>
    <div class="border border-amber-400/10 bg-amber-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-amber-400 shrink-0" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
      <p class="text-sm text-amber-400"><%= error %></p>
    </div>
    <% } %>
    <% if (success) { %>
    <div class="border border-green-400/10 bg-green-400/5 p-4 flex gap-x-3">
      <svg class="h-5 w-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
      <p class="text-sm text-green-400"><%= success %></p>
    </div>
    <% } %>

    <!-- Header -->
    <div class="flex items-center justify-between bg-zinc-700/10 border-b border-white/5 px-4 py-4 sm:px-6 lg:px-8">
      <div>
        <h1 class="text-base font-semibold text-white">Resource Store</h1>
        <p class="mt-1 text-xs text-zinc-400">Use coins to expand your resource pool.</p>
      </div>
      <div class="flex items-center gap-x-3">
        <div class="flex items-center gap-x-2 rounded-full bg-yellow-400/10 px-4 py-2 ring-1 ring-inset ring-yellow-400/20">
          <span class="text-base">🪙</span>
          <span class="text-sm font-semibold text-yellow-400"><%= user.coins %></span>
        </div>
        <a href="/earn" class="rounded-full bg-zinc-600/20 px-4 py-2 text-xs font-medium text-zinc-300 ring-1 ring-inset ring-white/10 hover:bg-zinc-600/30 transition">+ Earn Coins</a>
      </div>
    </div>

    <!-- Current pool -->
    <div class="px-4 sm:px-6 lg:px-8 pt-6">
      <h2 class="text-sm font-semibold text-zinc-300 mb-3">Your Current Pool</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
        <%
          const poolItems = [
            { label:'RAM',       val: (user.res_memory/1024).toFixed(1)+' GiB',  used:(user.used_memory/1024).toFixed(1)+' used' },
            { label:'Disk',      val: (user.res_disk/1024).toFixed(1)+' GiB',    used:(user.used_disk/1024).toFixed(1)+' used' },
            { label:'CPU',       val: user.res_cpu+'%',                           used:user.used_cpu+'% used' },
            { label:'Ports',     val: user.res_ports,                             used:user.used_ports+' used' },
            { label:'Databases', val: user.res_databases,                         used:user.used_databases+' used' },
            { label:'Backups',   val: user.res_backups,                           used:user.used_backups+' used' },
          ];
        %>
        <% poolItems.forEach(p => { %>
        <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-4">
          <p class="text-xs text-zinc-500"><%= p.label %></p>
          <p class="text-lg font-semibold text-white mt-1"><%= p.val %></p>
          <p class="text-xs text-zinc-600 mt-0.5"><%= p.used %></p>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- Store items grouped by type -->
    <%
      const groups = {
        memory:    { label:'RAM',       icon:'🧠', items:[] },
        disk:      { label:'Disk',      icon:'💾', items:[] },
        cpu:       { label:'CPU',       icon:'⚡', items:[] },
        ports:     { label:'Ports',     icon:'🔌', items:[] },
        databases: { label:'Databases', icon:'🗄️', items:[] },
        backups:   { label:'Backups',   icon:'📦', items:[] },
      };
      items.forEach(i => { if (groups[i.resource]) groups[i.resource].items.push(i); });
    %>
    <div class="px-4 sm:px-6 lg:px-8 pb-16 space-y-8">
      <% Object.values(groups).filter(g=>g.items.length).forEach(group => { %>
      <div>
        <h2 class="text-sm font-semibold text-zinc-300 mb-3"><%= group.icon %> <%= group.label %></h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <% group.items.forEach(item => { %>
          <div class="rounded-2xl bg-zinc-600/10 border border-white/5 p-5 flex items-center justify-between hover:border-white/10 transition">
            <div>
              <p class="text-sm font-medium text-white"><%= item.name %></p>
              <p class="text-xs text-zinc-500 mt-0.5"><%= item.description %></p>
            </div>
            <div class="flex flex-col items-end gap-y-2 ml-4 shrink-0">
              <div class="flex items-center gap-x-1 text-sm font-semibold text-yellow-400">
                <span>🪙</span><span><%= item.cost %></span>
              </div>
              <% if (user.coins >= item.cost) { %>
              <form action="/store/buy/<%= item.key %>" method="POST">
                <button type="submit" class="rounded-full bg-blue-400/10 px-4 py-1.5 text-xs font-medium text-blue-400 ring-1 ring-inset ring-blue-400/20 hover:bg-blue-400/20 transition">
                  Buy
                </button>
              </form>
              <% } else { %>
              <span class="rounded-full bg-zinc-700/30 px-4 py-1.5 text-xs font-medium text-zinc-600 ring-1 ring-inset ring-zinc-600/20 cursor-not-allowed">
                Buy
              </span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>

  </main>
</div>
</body>
</html>
