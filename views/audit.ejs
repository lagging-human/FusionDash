<!doctype html>
<html lang="en">
<%- include('../components/header') %>
<body>
<%- include('../components/sidebar', { activePage:'audit' }) %>

<div class="app-main">

  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-sm font-semibold text-white">Audit Log</p>
      <p class="text-xs text-zinc-500 mt-0.5"><%= pagination.total %> total entries</p>
    </div>
    <a href="/admin" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">&larr; Admin Panel</a>
  </div>

  <%- include('../components/admin_tabs', { adminTab: 'audit' }) %>

  <!-- Filters -->
  <form method="GET" action="/admin/audit" class="px-4 sm:px-6 lg:px-8 py-4 border-b border-white/[0.06] bg-white/[0.015]">
    <div class="flex flex-wrap items-end gap-3">
      <div>
        <label class="block text-xs text-zinc-500 mb-1">Action</label>
        <select name="action" class="rounded-lg border-none py-2 pl-3 pr-8 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm focus:ring-blue-400">
          <option value="">All actions</option>
          <% actions.forEach(a => { %>
          <option value="<%= a %>" <%= filters.action === a ? 'selected' : '' %>><%= a %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-xs text-zinc-500 mb-1">Admin</label>
        <input type="text" name="admin" value="<%= filters.admin %>" placeholder="Username..."
          class="rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm focus:ring-blue-400 w-36">
      </div>
      <div>
        <label class="block text-xs text-zinc-500 mb-1">From</label>
        <input type="date" name="from" value="<%= filters.from %>"
          class="rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm focus:ring-blue-400">
      </div>
      <div>
        <label class="block text-xs text-zinc-500 mb-1">To</label>
        <input type="date" name="to" value="<%= filters.to %>"
          class="rounded-lg border-none py-2 pl-3 bg-zinc-900 text-white ring-1 ring-inset ring-zinc-700 text-sm focus:ring-blue-400">
      </div>
      <button type="submit" class="rounded-full bg-blue-500/15 px-4 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
        Filter
      </button>
      <a href="/admin/audit" class="rounded-full bg-zinc-700/40 px-4 py-2 text-xs font-medium text-zinc-400 ring-1 ring-inset ring-white/10 hover:bg-zinc-700/60 transition-colors">
        Clear
      </a>
    </div>
  </form>

  <!-- Log table -->
  <div class="px-4 sm:px-6 lg:px-8 py-4 pb-16">
    <% if (!logs.length) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-14 text-center">
      <p class="text-sm text-zinc-500">No audit log entries found.</p>
    </div>
    <% } else { %>
    <div class="rounded-2xl border border-white/[0.06] overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm min-w-[700px]">
          <thead class="bg-white/[0.02] border-b border-white/[0.06]">
            <tr>
              <th class="py-3 pl-4 pr-4 text-xs font-semibold text-zinc-500 w-36">When</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500 w-28">Admin</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500 w-40">Action</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500">Target</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500">Detail</th>
              <th class="py-3 pr-4 text-xs font-semibold text-zinc-500 w-28">IP</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/[0.04]">
            <% logs.forEach(log => {
              const actionColor = log.action.startsWith('server.delete') || log.action.startsWith('user.revoke') ? 'text-red-400' :
                                  log.action.includes('create') || log.action.includes('grant') ? 'text-green-400' :
                                  log.action.includes('update') || log.action.includes('gift') ? 'text-blue-400' : 'text-zinc-400';
              let detail = '';
              try { detail = log.detail ? JSON.stringify(JSON.parse(log.detail), null, 0) : ''; } catch { detail = log.detail || ''; }
              if (detail.length > 80) detail = detail.slice(0, 77) + '…';
            %>
            <tr class="hover:bg-white/[0.015] transition-colors">
              <td class="py-3 pl-4 pr-4 text-xs text-zinc-600 whitespace-nowrap">
                <%= new Date(log.created_at).toLocaleString('en-IN', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' }) %>
              </td>
              <td class="py-3 pr-4 text-xs text-zinc-300 font-medium"><%= log.admin_name %></td>
              <td class="py-3 pr-4">
                <span class="font-mono text-xs <%= actionColor %>"><%= log.action %></span>
              </td>
              <td class="py-3 pr-4 text-xs text-zinc-400">
                <% if (log.target_name) { %>
                  <span class="text-zinc-300"><%= log.target_name %></span>
                  <span class="text-zinc-700 ml-1">(<%= log.target_type %>)</span>
                <% } else { %>
                  <span class="text-zinc-700"><%= log.target_type || '—' %></span>
                <% } %>
              </td>
              <td class="py-3 pr-4 text-xs text-zinc-600 font-mono max-w-xs truncate" title="<%= log.detail || '' %>">
                <%= detail || '—' %>
              </td>
              <td class="py-3 pr-4 text-xs text-zinc-700 font-mono"><%= log.ip || '—' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination -->
    <% if (pagination.pages > 1) { %>
    <div class="flex items-center justify-between mt-4">
      <p class="text-xs text-zinc-600">
        Showing <%= (pagination.page-1)*pagination.perPage+1 %>–<%= Math.min(pagination.page*pagination.perPage, pagination.total) %> of <%= pagination.total %>
      </p>
      <div class="flex items-center gap-x-1">
        <% if (pagination.page > 1) { %>
        <a href="?page=<%= pagination.page-1 %>&action=<%= filters.action %>&admin=<%= filters.admin %>&from=<%= filters.from %>&to=<%= filters.to %>"
          class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs text-zinc-300 hover:bg-zinc-700 transition-colors">&larr;</a>
        <% } %>
        <span class="px-3 py-1.5 text-xs text-zinc-500"><%= pagination.page %> / <%= pagination.pages %></span>
        <% if (pagination.page < pagination.pages) { %>
        <a href="?page=<%= pagination.page+1 %>&action=<%= filters.action %>&admin=<%= filters.admin %>&from=<%= filters.from %>&to=<%= filters.to %>"
          class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs text-zinc-300 hover:bg-zinc-700 transition-colors">&rarr;</a>
        <% } %>
      </div>
    </div>
    <% } %>
    <% } %>
  </div>
</div>
</body>
</html>
