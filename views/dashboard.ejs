<!doctype html>
<html lang="en">
<%- include('./components/header') %>
<body>
<%- include('./components/sidebar', { activePage:'dashboard' }) %>

<div class="app-main">

  <!-- Alerts -->
  <% if (error) { %>
  <div class="flex gap-x-3 border-b border-amber-500/20 bg-amber-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-amber-400 shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/></svg>
    <p class="text-sm text-amber-300"><%= error %></p>
  </div>
  <% } %>
  <% if (success) { %>
  <div class="flex gap-x-3 border-b border-green-500/20 bg-green-500/10 px-4 py-3 sm:px-6 lg:px-8">
    <svg class="h-5 w-5 text-green-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
    <p class="text-sm text-green-300"><%= success %></p>
  </div>
  <% } %>

  <!-- Page header -->
  <div class="flex flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06] bg-white/[0.02]">
    <div>
      <p class="text-xs text-zinc-500"><span class="text-zinc-300 font-medium"><%= user.username %></span> / Dashboard</p>
      <p class="text-xs text-zinc-600 mt-0.5">Your free servers and resource pool.</p>
    </div>
    <div class="flex items-center gap-x-2">
      <a href="/billing" class="inline-flex items-center gap-x-1.5 rounded-full bg-emerald-500/10 px-4 py-2 text-xs font-semibold text-emerald-400 ring-1 ring-inset ring-emerald-500/25 hover:bg-emerald-500/20 transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 21Z"/></svg>
        Billing
      </a>
      <a href="/servers/create" class="inline-flex items-center gap-x-1.5 rounded-full bg-blue-500/15 px-4 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        New Server
      </a>
    </div>
  </div>

  <!-- Resource Pool -->
  <div class="px-4 py-4 sm:px-6 lg:px-8 border-b border-white/[0.06]">
    <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
      <p class="text-[10px] font-semibold text-zinc-600 uppercase tracking-widest">Resource Pool</p>
      <div class="flex items-center gap-x-3">
        <a href="/store" class="text-xs text-blue-400 hover:text-blue-300 transition-colors font-medium">Buy more →</a>
        <div class="flex items-center gap-x-1.5 rounded-full bg-yellow-400/10 px-3 py-1 ring-1 ring-inset ring-yellow-400/20">
          <%- icon('coin', 'h-4 w-4 text-yellow-400') %>
          <span class="text-xs font-semibold text-yellow-400"><%= user.coins %></span>
        </div>
      </div>
    </div>
    <%
      const meters = [
        { label:'RAM',   used:user.used_memory,    total:user.res_memory,    fmt: v => (v/1024).toFixed(1)+' GiB' },
        { label:'Disk',  used:user.used_disk,      total:user.res_disk,      fmt: v => (v/1024).toFixed(1)+' GiB' },
        { label:'CPU',   used:user.used_cpu,       total:user.res_cpu,       fmt: v => v+'%' },
        { label:'Ports', used:user.used_ports,     total:user.res_ports,     fmt: v => v+'' },
        { label:'DBs',   used:user.used_databases, total:user.res_databases, fmt: v => v+'' },
        { label:'Backups',used:user.used_backups,  total:user.res_backups,   fmt: v => v+'' },
      ];
    %>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <% meters.forEach(m => {
        const pct = m.total > 0 ? Math.min(100, (m.used / m.total) * 100) : 0;
        const barColor = pct >= 100 ? '#ef4444' : pct > 75 ? '#f59e0b' : '#3b82f6';
      %>
      <div class="rounded-xl bg-white/[0.03] border border-white/[0.06] p-3">
        <div class="flex items-center justify-between mb-2">
          <span class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wide"><%= m.label %></span>
          <span class="text-[10px] text-zinc-600"><%= m.fmt(m.used) %> / <%= m.fmt(m.total) %></span>
        </div>
        <div class="h-1 w-full rounded-full bg-zinc-800">
          <div class="h-1 rounded-full transition-all" style="width:<%= pct.toFixed(1) %>%; background:<%= barColor %>"></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <!-- Free Servers -->
  <div class="px-4 pt-5 pb-10 sm:px-6 lg:px-8">
    <% const freeServers = servers.filter(s => s.plan === 'free'); %>
    <div class="flex items-center justify-between mb-3">
      <p class="text-sm font-semibold text-white">Free Servers</p>
      <div class="flex items-center gap-x-3">
        <% if (servers.filter(s => s.plan !== 'free').length > 0) { %>
        <a href="/billing" class="text-xs text-emerald-400 hover:text-emerald-300 transition-colors font-medium">View paid servers →</a>
        <% } %>
        <p class="text-xs text-zinc-600"><%= freeServers.length %> total</p>
      </div>
    </div>

    <% if (freeServers.length === 0) { %>
    <div class="rounded-2xl border border-dashed border-white/10 py-14 text-center">
      <svg class="mx-auto h-10 w-10 text-zinc-700 mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 0 0 3 3h7.5a3 3 0 0 0 3-3m-13.5 0V8.25m0 0a3 3 0 0 1 3-3h7.5a3 3 0 0 1 3 3m0 0v6m0-6h-13.5"/></svg>
      <p class="text-sm text-zinc-500">No free servers yet</p>
      <a href="/servers/create" class="mt-4 inline-block rounded-full bg-blue-500/15 px-5 py-2 text-xs font-semibold text-blue-400 ring-1 ring-inset ring-blue-500/30 hover:bg-blue-500/25 transition-colors">Create your first server</a>
    </div>
    <% } else { %>

    <!-- Desktop table -->
    <div class="hidden sm:block table-wrap rounded-2xl border border-white/[0.06] overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-white/[0.02] border-b border-white/[0.06]">
          <tr>
            <th class="py-3 pl-4 pr-6 text-xs font-semibold text-zinc-500">Name</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500 hidden lg:table-cell">Resources</th>
            <th class="py-3 pr-6 text-xs font-semibold text-zinc-500">Status</th>
            <th class="py-3 pr-4 text-xs font-semibold text-zinc-500 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/[0.04]">
          <% freeServers.forEach(server => {
            const ago = (() => { const d = Date.now()-new Date(server.created_at); const m=Math.floor(d/60000),h=Math.floor(m/60),dy=Math.floor(h/24); return dy>0?dy+'d ago':h>0?h+'h ago':m+'m ago'; })();
            const renewalDue = server.renewal_due ? new Date(server.renewal_due) : null;
            const renewalDaysLeft = renewalDue ? Math.ceil((renewalDue - Date.now()) / 86400000) : null;
            const renewalOverdue = renewalDaysLeft !== null && renewalDaysLeft <= 0;
            const renewalSoon   = renewalDaysLeft !== null && renewalDaysLeft > 0 && renewalDaysLeft <= 3;
          %>
          <tr class="hover:bg-white/[0.015] transition-colors">
            <td class="py-3.5 pl-4 pr-6">
              <div class="flex items-center gap-x-3">
                <div class="h-8 w-8 rounded-lg bg-zinc-500/10 flex items-center justify-center shrink-0">
                  <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 0 0 3 3h7.5a3 3 0 0 0 3-3m-13.5 0V8.25m0 0a3 3 0 0 1 3-3h7.5a3 3 0 0 1 3 3m0 0v6m0-6h-13.5"/></svg>
                </div>
                <div class="min-w-0">
                  <% if (server.pterodactyl_identifier && process.env.PTERODACTYL_PANEL_URL) { %>
                  <a href="<%= process.env.PTERODACTYL_PANEL_URL %>/server/<%= server.pterodactyl_identifier %>" target="_blank"
                    class="text-sm font-medium text-white hover:text-blue-400 transition-colors truncate block max-w-[160px]"><%= server.name %></a>
                  <% } else { %>
                  <span class="text-sm font-medium text-white truncate block max-w-[160px]"><%= server.name %></span>
                  <% } %>
                  <p class="text-xs text-zinc-600"><%= ago %></p>
                </div>
              </div>
            </td>
            <td class="py-3.5 pr-6 hidden lg:table-cell">
              <div class="flex flex-wrap gap-x-2 text-xs text-zinc-500">
                <span><%= (server.memory/1024).toFixed(1) %> GiB RAM</span>
                <span class="text-zinc-700">·</span>
                <span><%= (server.disk/1024).toFixed(1) %> GiB Disk</span>
                <span class="text-zinc-700">·</span>
                <span><%= (server.cpu/100).toFixed(1) %> CPU</span>
              </div>
            </td>
            <td class="py-3.5 pr-6">
              <div class="flex items-center gap-x-1.5">
                <span class="h-1.5 w-1.5 rounded-full bg-green-400 shrink-0"></span>
                <span class="text-xs text-zinc-400">Online</span>
              </div>
            </td>
            <td class="py-3.5 pr-4 text-right">
              <div class="flex items-center justify-end gap-x-2 flex-wrap gap-y-1">
                <% if (renewal.enabled && renewalDue) { %>
                  <% if (server.renewal_suspended) { %>
                    <span class="rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400">Suspended</span>
                    <form action="/servers/<%= server.id %>/renew" method="POST" class="inline">
                      <button type="submit" class="rounded-lg border border-yellow-500/30 bg-yellow-500/10 px-3 py-1.5 text-xs font-medium text-yellow-400 hover:bg-yellow-500/15 transition-colors">
                        Renew (<%= renewal.price %> coins)
                      </button>
                    </form>
                  <% } else if (renewalOverdue) { %>
                    <span class="rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-1.5 text-xs font-medium text-red-400">Overdue</span>
                    <form action="/servers/<%= server.id %>/renew" method="POST" class="inline">
                      <button type="submit" class="rounded-lg border border-red-500/30 bg-red-500/10 px-3 py-1.5 text-xs font-semibold text-red-400 hover:bg-red-500/15 transition-colors">Renew now</button>
                    </form>
                  <% } else if (renewalSoon) { %>
                    <form action="/servers/<%= server.id %>/renew" method="POST" class="inline">
                      <button type="submit" class="rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-1.5 text-xs font-medium text-amber-400 hover:bg-amber-500/15 transition-colors">
                        Renew in <%= renewalDaysLeft %>d
                      </button>
                    </form>
                  <% } else { %>
                    <span class="text-xs text-zinc-600">Due <%= renewalDue.toLocaleDateString('en-IN') %></span>
                  <% } %>
                <% } %>
                <a href="/servers/<%= server.id %>/edit" class="rounded-lg border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs font-medium text-zinc-300 hover:border-white/20 hover:text-white transition-colors">Edit</a>
                <a href="/servers/<%= server.id %>/delete" class="rounded-lg border border-red-500/20 bg-red-500/5 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-500/10 transition-colors">Delete</a>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="sm:hidden space-y-3">
      <% freeServers.forEach(server => {
        const ago = (() => { const d=Date.now()-new Date(server.created_at); const m=Math.floor(d/60000),h=Math.floor(m/60),dy=Math.floor(h/24); return dy>0?dy+'d ago':h>0?h+'h ago':m+'m ago'; })();
      %>
      <div class="rounded-2xl border border-white/[0.06] bg-white/[0.02] p-4">
        <div class="flex items-start justify-between gap-x-3 mb-3">
          <div class="min-w-0">
            <% if (server.pterodactyl_identifier && process.env.PTERODACTYL_PANEL_URL) { %>
            <a href="<%= process.env.PTERODACTYL_PANEL_URL %>/server/<%= server.pterodactyl_identifier %>" target="_blank"
              class="text-sm font-semibold text-white truncate block"><%= server.name %></a>
            <% } else { %>
            <p class="text-sm font-semibold text-white truncate"><%= server.name %></p>
            <% } %>
            <p class="text-xs text-zinc-600 mt-0.5"><%= ago %></p>
          </div>
          <span class="shrink-0 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-zinc-500/15 text-zinc-400">Free</span>
        </div>
        <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs text-zinc-500 mb-3">
          <span><%= (server.memory/1024).toFixed(1) %> GiB RAM</span>
          <span><%= (server.disk/1024).toFixed(1) %> GiB Disk</span>
          <span><%= (server.cpu/100).toFixed(1) %> CPU</span>
        </div>
        <div class="flex items-center gap-x-2">
          <a href="/servers/<%= server.id %>/edit" class="flex-1 text-center rounded-lg border border-white/10 bg-white/[0.03] py-2 text-xs font-medium text-zinc-300 hover:border-white/20 transition-colors">Edit</a>
          <a href="/servers/<%= server.id %>/delete" class="flex-1 text-center rounded-lg border border-red-500/20 bg-red-500/5 py-2 text-xs font-medium text-red-400 hover:bg-red-500/10 transition-colors">Delete</a>
        </div>
      </div>
      <% }) %>
    </div>
    <% } %>
  </div>

</div><!-- /.app-main -->

  <!-- Queue status widget -->
  <div id="queueWidget" class="hidden fixed bottom-5 right-5 z-50 w-80 rounded-2xl border border-blue-500/20 bg-[#0c0d0f] shadow-2xl overflow-hidden">
    <div class="flex items-center gap-x-2 px-4 py-3 border-b border-white/[0.06] bg-blue-500/5">
      <div id="queueSpinner" class="h-3 w-3 rounded-full border-2 border-blue-400 border-t-transparent animate-spin"></div>
      <p class="text-xs font-semibold text-blue-400" id="queueHeader">Server Queue</p>
      <button onclick="document.getElementById('queueWidget').classList.add('hidden')" class="ml-auto text-zinc-600 hover:text-zinc-300">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div id="queueJobs" class="divide-y divide-white/[0.04] max-h-48 overflow-y-auto"></div>
  </div>

<style>
@keyframes spin { to { transform: rotate(360deg); } }
.animate-spin { animation: spin 1s linear infinite; }
</style>

<script>
const statusColor = { pending:'text-zinc-500', processing:'text-blue-400', done:'text-green-400', failed:'text-red-400' };
const statusLabel = { pending:'Queued', processing:'Creating…', done:'Ready', failed:'Failed' };

function fmtEta(seconds) {
  if (!seconds || seconds <= 0) return 'soon';
  const m = Math.floor(seconds / 60), s = seconds % 60;
  return m > 0 ? `~${m}m ${s > 0 ? s+'s' : ''}` : `~${s}s`;
}

const seenDoneJobs = new Set();

async function pollQueue() {
  try {
    const res  = await fetch('/api/queue');
    const data = await res.json();
    const active = data.jobs.filter(j => j.status === 'pending' || j.status === 'processing');
    const widget = document.getElementById('queueWidget');
    const list   = document.getElementById('queueJobs');
    const header = document.getElementById('queueHeader');

    if (!data.jobs.length) { widget.classList.add('hidden'); return; }
    widget.classList.remove('hidden');

    if (header && data.info) {
      const { pending, active: act, etaSeconds } = data.info;
      header.textContent = act > 0
        ? `Creating… ${pending > 0 ? pending + ' queued · ETA ' + fmtEta(etaSeconds) : ''}`
        : pending > 0 ? `${pending} in queue · ETA ${fmtEta(etaSeconds)}` : 'Queue idle';
    }

    list.innerHTML = data.jobs.slice(0, 8).map(j => `
      <div class="px-4 py-2.5 flex items-start justify-between gap-x-3">
        <div class="min-w-0">
          <p class="text-xs text-zinc-300 truncate">Job #${j.id}</p>
          ${j.position ? `<p class="text-[10px] text-zinc-600">Position ${j.position} · ETA ${fmtEta((j.position - 1) * (data.info?.delaySeconds || 120))}</p>` : ''}
          ${j.error ? `<p class="text-[10px] text-red-400/70 mt-0.5 truncate">${j.error}</p>` : ''}
        </div>
        <div class="flex items-center gap-x-1.5 shrink-0">
          ${j.status === 'processing' ? '<div class="h-2 w-2 rounded-full border border-blue-400 border-t-transparent animate-spin"></div>' : ''}
          <span class="text-xs font-medium ${statusColor[j.status] || 'text-zinc-500'}">${statusLabel[j.status] || j.status}</span>
        </div>
      </div>
    `).join('');

    document.getElementById('queueSpinner').style.display = active.length ? '' : 'none';

    // Only reload once per newly-completed job, never again for the same job
    const newlyDone = data.jobs.filter(j => j.status === 'done' && j.server_id && !seenDoneJobs.has(j.id));
    if (newlyDone.length && !window._reloading) {
      newlyDone.forEach(j => seenDoneJobs.add(j.id));
      window._reloading = true;
      setTimeout(() => location.reload(), 1500);
    } else {
      // Mark all done jobs as seen so future polls don't re-trigger
      data.jobs.filter(j => j.status === 'done').forEach(j => seenDoneJobs.add(j.id));
    }
  } catch {}
}

pollQueue();
setInterval(pollQueue, 3000);
</script>
</body>
</html>
