# App
SESSION_SECRET=change_this_to_a_random_long_string
BASE_URL=http://localhost:3000
PORT=3000

# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Google OAuth2 (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Pterodactyl Panel
PTERODACTYL_PANEL_URL=https://panel.example.com
PTERODACTYL_API_KEY=

# Default deploy target for new servers (find these in your Pterodactyl admin panel)
PTERODACTYL_DEFAULT_NEST_ID=1
PTERODACTYL_DEFAULT_EGG_ID=2
PTERODACTYL_DEFAULT_LOCATION_ID=1

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# PayPal (https://developer.paypal.com/dashboard)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
